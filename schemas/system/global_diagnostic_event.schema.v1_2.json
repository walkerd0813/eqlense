{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "equity_lens.schemas.system.global_diagnostic_event.v1_2",
  "title": "Global Diagnostic Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "diagnostic_id",
    "timestamp",
    "severity",
    "layer",
    "engine",
    "stage",
    "symptom"
  ],
  "properties": {
    "schema": { "type": "string", "const": "equity_lens.global_diagnostic_event.v1_2" },

    "diagnostic_id": {
      "type": "string",
      "description": "UUID (preferred) or stable unique id",
      "minLength": 8
    },
    "parent_diagnostic_id": {
      "type": "string",
      "description": "If this is caused by another diagnostic event"
    },
    "correlation_id": {
      "type": "string",
      "description": "Ties multiple diagnostics across a DAG/run/session"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp (timezone-aware)"
    },

    "severity": {
      "type": "string",
      "enum": ["INFO", "WARN", "SOFT_FAIL", "HARD_FAIL"]
    },

    "layer": {
      "type": "string",
      "enum": [
        "INGESTION",
        "ATTACHMENT",
        "ENGINE",
        "GATE",
        "UI",
        "SELF_HEAL",
        "RECONCILIATION",
        "OCR"
      ]
    },

    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine_key"],
      "properties": {
        "engine_key": { "type": "string", "description": "e.g. market_radar, zoning_attach, deeds_ingest" },
        "engine_id": { "type": "string", "description": "registry engine_id if applicable" },
        "engine_version": { "type": "string" },
        "run_id": { "type": "string" },
        "session_id": { "type": "string", "description": "governance session id if applicable" }
      }
    },

    "stage": {
      "type": "string",
      "description": "High-level stage label (human-friendly); use pipeline.stage for strict stage machine"
    },

    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dag_id": { "type": "string" },
        "dag_version": { "type": "string" },
        "task_id": { "type": "string" },
        "attempt": { "type": "integer", "minimum": 0 },
        "state": {
          "type": "string",
          "enum": ["RECEIVED", "PREFLIGHT", "EXTRACT", "NORMALIZE", "ATTACH", "VALIDATE", "FREEZE", "CURRENT", "DOWNSTREAM"]
        },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },

    "failure_class": {
      "type": "string",
      "enum": [
        "MISSING_DATA",
        "LOW_CONFIDENCE",
        "CONFLICT",
        "SCHEMA_MISMATCH",
        "STALE_INPUT",
        "STALE_GATE",
        "UNSUPPORTED_BUCKET",
        "INSUFFICIENT_SAMPLES",
        "MISSING_METRIC",
        "PARSE_ERROR",
        "JOIN_KEY_MISSING",
        "CRS_INVALID",
        "GEOMETRY_INVALID",
        "BBOX_FAIL",
        "DUPLICATE",
        "PERMISSION",
        "IO_ERROR",
        "UNKNOWN"
      ]
    },

    "event_type_norm": {
      "type": "string",
      "enum": [
        "DEED",
        "FORECLOSURE_DEED",
        "MORTGAGE",
        "ASSIGNMENT",
        "DISCHARGE",
        "RELEASE",
        "LIEN_MUNICIPAL",
        "LIEN_FEDERAL",
        "LIEN_STATE",
        "LIEN_JUDGMENT",
        "LIS_PENDENS",
        "PERMIT",
        "MLS_EVENT",
        "POLICY_BILL",
        "POLICY_RULE",
        "RENT_FMR",
        "UNKNOWN"
      ]
    },

    "instrument_class": {
      "type": "string",
      "enum": [
        "TRANSFER",
        "FINANCING",
        "FINANCING_CHANGE",
        "SECURITY_INTEREST",
        "ENCUMBRANCE",
        "ENCUMBRANCE_RELEASE",
        "LITIGATION",
        "REGULATORY",
        "MARKET",
        "POLICY",
        "RENT",
        "UNKNOWN"
      ]
    },

    "entity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity_type": { "type": "string", "description": "parcel|property|event|listing|document|layer_feature|dag_task|gate" },
        "entity_id": { "type": "string" },

        "property_id": { "type": "string" },
        "parcel_id": { "type": "string" },
        "listing_id": { "type": "string" },
        "event_id": { "type": "string" },
        "doc_hash": { "type": "string" },

        "county": { "type": "string" },
        "town": { "type": "string" },
        "zip": { "type": "string" }
      }
    },

    "symptom": { "type": "string", "minLength": 3 },

    "root_causes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cause_type", "description"],
        "properties": {
          "cause_type": { "type": "string", "enum": ["DATA", "LOGIC", "TIMING", "SOURCE", "CONFIG", "PERMISSION", "UNKNOWN"] },
          "description": { "type": "string" },
          "evidence": { "type": "object", "additionalProperties": true }
        }
      }
    },

    "attempted_fixes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["strategy", "result"],
        "properties": {
          "strategy": { "type": "string" },
          "result": { "type": "string", "enum": ["SUCCESS", "FAILED", "SKIPPED"] },
          "confidence_change": { "type": "number" },
          "notes": { "type": "string" }
        }
      }
    },

    "recommended_actions": {
      "type": "array",
      "default": [],
      "items": { "type": "string" }
    },

    "block_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_blocking": { "type": "boolean" },
        "gate_id": { "type": "string" },
        "override_allowed": { "type": "boolean" },
        "override_reason_required": { "type": "boolean" }
      }
    },

    "confidence_impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before": { "type": "number", "minimum": 0, "maximum": 1 },
        "after": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "evidence": {
      "type": "object",
      "description": "Deterministic evidence used to reach the diagnostic (keys, methods, hashes)",
      "additionalProperties": true
    },

    "lineage": {
      "type": "object",
      "description": "Inputs/outputs used in this stage (paths + hashes)",
      "additionalProperties": true
    },

    "artifacts": {
      "type": "object",
      "description": "Artifacts produced/affected",
      "additionalProperties": true
    },

    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contains_pii": { "type": "boolean" },
        "redactions_applied": { "type": "array", "items": { "type": "string" }, "default": [] },
        "secrets_present": { "type": "boolean", "const": false }
      }
    },

    "debug": {
      "type": "object",
      "description": "Safe-to-log debug payload (no secrets)",
      "additionalProperties": true
    }
  }
}
