{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "equity_lens.schemas.system.global_diagnostic_event.v1_1",
  "title": "Global Diagnostic Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "diagnostic_id",
    "timestamp",
    "severity",
    "layer",
    "engine",
    "stage",
    "symptom"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "equity_lens.global_diagnostic_event.v1_1"
    },
    "diagnostic_id": {
      "type": "string",
      "minLength": 8
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp (timezone-aware)"
    },
    "severity": {
      "type": "string"
    },
    "layer": {
      "type": "string"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_key"
      ],
      "properties": {
        "engine_key": {
          "type": "string",
          "description": "e.g. market_radar, zoning_attach, deeds_ingest"
        },
        "engine_id": {
          "type": "string",
          "description": "registry engine_id if applicable"
        },
        "engine_version": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        }
      }
    },
    "stage": {
      "type": "string"
    },
    "failure_class": {
      "type": "string"
    },
    "event_type_norm": {
      "type": "string",
      "description": "Normalized type (deed/mortgage/permit/etc.)"
    },
    "instrument_class": {
      "type": "string"
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity_type": {
          "type": "string"
        },
        "entity_id": {
          "type": "string"
        },
        "property_id": {
          "type": "string"
        },
        "parcel_id": {
          "type": "string"
        },
        "listing_id": {
          "type": "string"
        },
        "doc_hash": {
          "type": "string"
        },
        "county": {
          "type": "string"
        },
        "town": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        }
      }
    },
    "symptom": {
      "type": "string",
      "minLength": 3
    },
    "root_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cause_type",
          "description"
        ],
        "properties": {
          "cause_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "evidence": {
            "type": "object"
          }
        }
      },
      "default": []
    },
    "attempted_fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "strategy",
          "result"
        ],
        "properties": {
          "strategy": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "confidence_change": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "block_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_blocking": {
          "type": "boolean"
        },
        "gate_id": {
          "type": "string"
        },
        "override_allowed": {
          "type": "boolean"
        },
        "override_reason_required": {
          "type": "boolean"
        }
      }
    },
    "confidence_impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before": {
          "type": "number"
        },
        "after": {
          "type": "number"
        }
      }
    },
    "lineage": {
      "type": "object",
      "description": "Inputs/outputs used in this stage (paths + hashes)",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "description": "Artifacts produced/affected",
      "additionalProperties": true
    },
    "debug": {
      "type": "object",
      "description": "Safe-to-log debug payload (no secrets)",
      "additionalProperties": true
    }
  }
}