{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://equitylens.local/schemas/phase5/registry_event_deed_min.schema.json",
  "title": "EquityLens Phase5 Registry Event (DEED) - Minimum Contract v1.1 (Recorded+LandCourt)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_id",
    "event_type",
    "registry",
    "index_layout",
    "property_ref",
    "recording",
    "document",
    "consideration",
    "parties",
    "attach",
    "source",
    "meta"
  ],
  "properties": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "equitylens.registry_event" },
        "version": { "type": "string", "pattern": "^phase5_deed_min_v1_1$" }
      }
    },

    "event_id": { "type": "string", "minLength": 12 },
    "event_type": { "const": "DEED" },

    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "county"],
      "properties": {
        "state": { "type": "string", "minLength": 2, "maxLength": 2 },
        "county": { "type": "string", "minLength": 2 },
        "district": { "type": ["string", "null"] }
      }
    },

    "index_layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "header_fingerprint"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["RECORDED_LAND", "LAND_COURT", "UNKNOWN"]
        },
        "header_fingerprint": {
          "type": ["string", "null"],
          "description": "Short fingerprint of the header line(s) used to detect layout."
        }
      }
    },

    "property_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["town_raw", "address_raw", "town_norm", "address_norm"],
      "properties": {
        "town_raw": { "type": ["string", "null"] },
        "address_raw": { "type": ["string", "null"] },

        "town_norm": { "type": ["string", "null"] },
        "address_norm": { "type": ["string", "null"] },

        "state": { "type": ["string", "null"], "default": "MA" },
        "zip5": { "type": ["string", "null"], "pattern": "^[0-9]{5}$" },

        "multi_address": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["town_raw", "address_raw"],
            "properties": {
              "town_raw": { "type": ["string", "null"] },
              "address_raw": { "type": ["string", "null"] }
            }
          },
          "default": [],
          "description": "If the index row lists multiple Addr lines (e.g., 110/120/130 MAPLE ST), store all here; primary town/address_raw remain the first."
        }
      }
    },

    "recording": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recorded_at_raw", "recording_date"],
      "properties": {
        "recorded_at_raw": {
          "type": ["string", "null"],
          "description": "Original recorded date/time token(s) from the index (e.g., '12-31-2024  8:58:00a')."
        },
        "recording_date": {
          "type": ["string", "null"],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "recording_time": { "type": ["string", "null"] },

        "book": { "type": ["string", "null"] },
        "page": { "type": ["string", "null"] },

        "doc_number": { "type": ["string", "null"] },
        "instrument_number": { "type": ["string", "null"], "description": "Index column often labeled INST #." },

        "group_seq": { "type": ["string", "null"], "description": "Index column often labeled GRP-SEQ." },

        "reference_book": { "type": ["string", "null"] },
        "reference_page": { "type": ["string", "null"] },

        "fee": { "type": ["number", "null"] },

        "verify_flag": { "type": ["string", "null"], "description": "VFY column values if present (e.g., 'Y')." },
        "status_flag": { "type": ["string", "null"], "description": "STS column values if present." }
      }
    },

    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_type", "instrument_type", "raw_block"],
      "properties": {
        "document_type": { "type": ["string", "null"], "default": "DEED" },

        "instrument_type": {
          "type": ["string", "null"],
          "description": "If you later parse a more specific instrument type; otherwise null is acceptable."
        },

        "index_doc_type": {
          "type": ["string", "null"],
          "description": "The TYPE column from index line (e.g., 'DEED')."
        },

        "descr_loc_delivered": {
          "type": ["string", "null"],
          "description": "Text from the DESCR/LOC/DELIVERED (or similar) column when present."
        },

        "raw_block": {
          "type": ["string", "null"],
          "description": "Full raw text block for this event row from the PDF index. Required for audit shield."
        },

        "pages_ref": {
          "type": ["string", "null"],
          "description": "Optional URL/path/id that could be used to retrieve full deed PDF later."
        }
      }
    },

    "consideration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency", "is_present", "source", "confidence", "reason_missing", "raw_text"],
      "properties": {
        "amount": { "type": ["number", "null"] },
        "currency": { "type": "string", "default": "USD" },

        "is_present": { "type": "boolean" },

        "source": {
          "type": "string",
          "enum": ["INDEX", "DEED_PDF", "ASSESSOR", "MLS_JOIN", "OTHER", "UNKNOWN"]
        },

        "confidence": { "type": "string", "enum": ["A", "B", "C", "D", "UNKNOWN"] },

        "reason_missing": {
          "type": ["string", "null"],
          "enum": [
            "NOT_IN_INDEX",
            "PARSE_FAIL",
            "NO_DOC_REF",
            "NO_MATCH_FOUND",
            "WITHHELD_OR_REDACTED",
            "UNKNOWN"
          ]
        },

        "raw_text": {
          "type": ["string", "null"],
          "description": "Raw captured consideration token from the index (e.g., '2,025,000.00', '100.00'). Always store when visible."
        }
      }
    },

    "parties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grantor", "grantee", "parser_status", "raw_lines"],
      "properties": {
        "grantor": { "type": "array", "items": { "type": "string" }, "default": [] },
        "grantee": { "type": "array", "items": { "type": "string" }, "default": [] },

        "parser_status": {
          "type": "string",
          "enum": ["UNPARSED", "PARSED_PARTIAL", "PARSED_OK", "MISSING_IN_SOURCE"],
          "default": "UNPARSED"
        },

        "raw_lines": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Store the raw party lines exactly as captured (e.g., '1 P SEDOR DEBORAH I')."
        }
      }
    },

    "attach": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attach_status", "property_id", "match_method", "match_key", "evidence"],
      "properties": {
        "attach_status": {
          "type": "string",
          "enum": [
            "ATTACHED_A",
            "UNKNOWN",
            "MISSING_TOWN_OR_ADDRESS",
            "COLLISION_AMBIGUOUS",
            "SPINE_KEY_NOT_FOUND"
          ]
        },
        "property_id": { "type": ["string", "null"] },

        "match_method": { "type": ["string", "null"] },
        "match_key": { "type": ["string", "null"] },

        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "join_method",
            "join_basis",
            "spine_version",
            "spine_dataset_hash",
            "events_version",
            "events_dataset_hash"
          ],
          "properties": {
            "join_method": { "type": "string", "enum": ["town+address_norm", "town+address_variants"] },
            "join_basis": { "type": "string", "enum": ["deterministic_only"] },

            "spine_version": { "type": ["string", "null"] },
            "spine_dataset_hash": { "type": ["string", "null"] },

            "events_version": { "type": ["string", "null"] },
            "events_dataset_hash": { "type": ["string", "null"] },

            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "as_of_date", "dataset_hash", "layout_kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["registry_index_pdf", "registry_api", "assessor", "mls", "other"] },
        "name": { "type": "string" },
        "as_of_date": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "dataset_hash": { "type": ["string", "null"] },
        "uri": { "type": ["string", "null"] },

        "layout_kind": {
          "type": "string",
          "enum": ["RECORDED_LAND", "LAND_COURT", "UNKNOWN"],
          "description": "Duplicate of index_layout.kind for quick filtering in downstream pipelines."
        }
      }
    },

    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "pipeline", "run_id"],
      "properties": {
        "created_at": { "type": "string" },
        "pipeline": { "type": "string", "default": "phase5_registry_events" },
        "run_id": { "type": "string" },

        "qa_flags": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    }
  }
}
