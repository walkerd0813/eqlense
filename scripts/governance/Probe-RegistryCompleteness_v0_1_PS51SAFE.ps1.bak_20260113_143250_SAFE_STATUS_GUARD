param(
  [Parameter(Mandatory=$true)][string]$Root,
  [switch]$FailOnWarn
)
Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

function LoadRegistry([string]$Root){
  $gov = Join-Path $Root "governance\engine_registry\ENGINE_REGISTRY.json"
  $rootReg = Join-Path $Root "ENGINE_REGISTRY.json"
  if(Test-Path $gov){ return [pscustomobject]@{ path=$gov; obj=((Get-Content $gov -Raw -Encoding UTF8) | ConvertFrom-Json) } }
  if(Test-Path $rootReg){ return [pscustomobject]@{ path=$rootReg; obj=((Get-Content $rootReg -Raw -Encoding UTF8) | ConvertFrom-Json) } }
  throw ("[error] missing ENGINE_REGISTRY.json (expected {0} or {1})" -f $gov, $rootReg)
}

function HasProp($obj,[string]$name){
  if($null -eq $obj){ return $false }
  return ($obj.PSObject.Properties.Match($name).Count -gt 0)
}

function NormRel([string]$p){
  if([string]::IsNullOrWhiteSpace($p)){ return "" }
  $x = $p.Trim()
  $x = $x.Replace("/","\")
  # strip leading .\ or \
  if($x.StartsWith(".\")){ $x = $x.Substring(2) }
  while($x.StartsWith("\")){ $x = $x.Substring(1) }
  return $x
}

$lr = LoadRegistry $Root
$regPath = $lr.path
$reg = $lr.obj
if(-not (HasProp $reg "engines")){ throw ("[error] registry missing .engines: {0}" -f $regPath) }

$warns = New-Object System.Collections.Generic.List[string]
$oks = 0
$total = 0

foreach($e in $reg.engines){
  $total += 1
  $engineId = $e.engine_id
  $status = $e.status
  if([string]::IsNullOrWhiteSpace($engineId)){ $warns.Add("MISSING_ENGINE_ID") | Out-Null; continue }

  # Only enforce runner completeness for active engines (institutional guard)
  if($status -ne "active"){ continue }

  if(-not (HasProp $e "runner")){
    $warns.Add(("ACTIVE_ENGINE_MISSING_RUNNER|{0}" -f $engineId)) | Out-Null
    continue
  }

  $r = $e.runner
  if(-not (HasProp $r "cmd") -or [string]::IsNullOrWhiteSpace($r.cmd)){
    $warns.Add(("RUNNER_MISSING_CMD|{0}" -f $engineId)) | Out-Null
  }
  if(-not (HasProp $r "args_template") -or [string]::IsNullOrWhiteSpace($r.args_template)){
    $warns.Add(("RUNNER_MISSING_ARGS_TEMPLATE|{0}" -f $engineId)) | Out-Null
  }

  # script relpath existence check (prevents FromScript autodetect + drift)
  $rel = ""
  if(HasProp $r "script_relpath" -and -not [string]::IsNullOrWhiteSpace($r.script_relpath)){
    $rel = NormRel $r.script_relpath
  }
  if($rel -ne ""){
    $full = Join-Path $Root $rel
    if(-not (Test-Path $full)){
      $warns.Add(("SCRIPT_RELPATH_MISSING_ON_DISK|{0}|{1}" -f $engineId, $rel)) | Out-Null
    }
  } else {
    $warns.Add(("RUNNER_MISSING_SCRIPT_RELPATH|{0}" -f $engineId)) | Out-Null
  }

  $oks += 1
}

Write-Host "============================================================"
Write-Host "[probe] Registry Completeness v0_1"
Write-Host ("  registry: {0}" -f $regPath)
Write-Host ("  active_engines_checked: {0}" -f $oks)
Write-Host ("  engines_total: {0}" -f $total)
Write-Host "============================================================"

if($warns.Count -gt 0){
  Write-Host ("[warn] issues: {0}" -f $warns.Count)
  foreach($w in $warns){ Write-Host ("  - {0}" -f $w) }
  if($FailOnWarn){ throw ("[error] registry completeness WARN (FailOnWarn) count={0}" -f $warns.Count) }
} else {
  Write-Host "[ok] registry completeness PASS (no warnings)"
}
