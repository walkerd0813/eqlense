import os, json, argparse, re, hashlib
import datetime
from datetime import timezone

import fitz
import pytesseract
from PIL import Image

pytesseract.pytesseract.tesseract_cmd = r"C:\Program Files\Tesseract-OCR\tesseract.exe"

STREET_WORD = r"(ST|STREET|AVE|AVENUE|RD|ROAD|DR|DRIVE|LN|LANE|BLVD|BOULEVARD|CT|COURT|PL|PLACE|TER|TERRACE|WAY|PKWY|PARKWAY|HWY|HIGHWAY|CIR|CIRCLE|SQ|SQUARE)"

POS_CUES = [
  ("VACANT LAND LOCATED AT", 10),

  ("PROPERTY ADDRESS", 12),
  ("LOCUS", 12),
  ("PREMISES KNOWN AS", 10),
  ("KNOWN AS", 6),
  ("SITUATED AT", 8),
  ("LOCATED AT", 8),
  ("BEING THE PREMISES", 10),
  ("THE LAND WITH BUILDINGS THEREON", 10),
  ("STREET ADDRESS OF THE PROPERTY", 12),
  ("SAID PREMISES", 4),
  ("AFORESAID PREMISES", 4),
]
NEG_CUES = [
  ("NOW OF", -10),
  ("WITH AN ADDRESS OF", -12),
  ("ADDRESS OF", -6),

  ("PLEASE RETURN TO", -14),
  ("RETURN TO", -10),
  ("RETURN ADDRESS", -14),
  ("MAIL TO", -10),
  ("MAILING ADDRESS", -12),
  ("WHOSE ADDRESS IS", -10),
  ("ATTORNEY", -8),
  ("LAW OFFICE", -8),
  ("ESQ", -6),
  ("P.C.", -6),
  ("LLP", -6),
]

def clean_text(s: str) -> str:
    if not s: return ""
    s = s.replace("\u2019", "'").replace("\u201c", '"').replace("\u201d", '"')
    s = s.replace("â€™", "'").replace("â€œ", '"').replace("â€�", '"')
    s = re.sub(r"[ \t]+", " ", s)
    s = re.sub(r"\n{3,}", "\n\n", s)
    return s.strip()

def norm_addr(s: str):
    if not s: return None
    s = s.upper()
    s = re.sub(r"[.]", "", s)
    s = re.sub(r"\s+", " ", s).strip()
    s = re.sub(r"\s*,\s*", ", ", s)
    return s

def sha1(s: str):
    return hashlib.sha1((s or "").encode("utf-8", errors="ignore")).hexdigest()

def render_region(page, rect, dpi):
    mat = fitz.Matrix(dpi/72.0, dpi/72.0)
    clip = fitz.Rect(rect)
    pix = page.get_pixmap(matrix=mat, clip=clip, alpha=False)
    img = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
    return img

def ocr_regions(pdf_path: str, page_limit: int, dpi: int, config: str):
    doc = fitz.open(pdf_path)
    blocks = []
    total_len = 0

    n = min(page_limit, doc.page_count)
    for i in range(n):
        page = doc.load_page(i)
        w, h = page.rect.width, page.rect.height

        regions = [
            ("top",  (0, 0, w, h*0.30)),
            ("left", (0, 0, w*0.22, h)),
            ("mid",  (0, h*0.25, w, h*0.80)),
            ("full", (0, 0, w, h))
        ]

        for name, r in regions:
            img = render_region(page, r, dpi)
            txt = pytesseract.image_to_string(img, lang="eng", config=config) or ""
            txt = clean_text(txt)
            if txt:
                blocks.append({"page": i, "region": name, "text": txt})
                total_len += len(txt)

    doc.close()
    merged = "\n\n".join([f"===PAGE {b['page']} REGION {b['region']}===\n{b['text']}" for b in blocks])
    return merged, blocks, total_len

def find_address_candidates(text: str):
    t = text or ""
    cand = []

    # Strong full MA address
    rx_full = re.compile(r"\b([0-9]{1,6}\s+[^,\n]{2,80}\b" + STREET_WORD + r"\b[^,\n]*,\s*[^,\n]{2,50},\s*MA\s*\d{5})\b", re.I)
    # Medium city+MA
    rx_ma = re.compile(r"\b([0-9]{1,6}\s+[^,\n]{2,80}\b" + STREET_WORD + r"\b[^,\n]*,\s*[^,\n]{2,50},\s*MA)\b", re.I)
    # Weak number+street only
    rx_weak = re.compile(r"\b([0-9]{1,6}\s+[A-Z0-9 .'\-]{2,50}\b" + STREET_WORD + r"\b)\b", re.I)

    for rx, strength in [(rx_full, "full"), (rx_ma, "ma"), (rx_weak, "weak")]:
        for m in rx.finditer(t):
            s = m.group(1).strip()
            start = m.start(1)
            cand.append({"value": s, "strength": strength, "start": start})

    # Dedup by normalized string
    seen = set()
    out = []
    for c in cand:
        key = norm_addr(c["value"]) or c["value"].upper()
        if key in seen:
            continue
        seen.add(key)
        out.append(c)

    return out

def score_candidate(text: str, start: int, val: str):
    t = text or ""
    lo = t.lower()

    # window ±150 chars
    a = max(0, start - 150)
    b = min(len(t), start + len(val) + 150)
    win = t[a:b].upper()

    score = 0
    hits = []

    for cue, pts in POS_CUES:
        if cue in win:
            score += pts
            hits.append({"cue": cue, "pts": pts})

    for cue, pts in NEG_CUES:
        if cue in win:
            score += pts
            hits.append({"cue": cue, "pts": pts})

    # light tie-breakers
    freq = len(re.findall(re.escape(val), t, flags=re.I))
    if freq > 1:
        score += min(4, freq)  # max +4
        hits.append({"cue": "FREQ", "pts": min(4, freq)})

    if "BOSTON" in win:
        score += 2
        hits.append({"cue": "LOCALITY_BOSTON", "pts": 2})

    return score, hits, win[:220]

def choose_property_address(text: str, candidates):
    scored = []
    for c in candidates:
        sc, hits, snippet = score_candidate(text, c["start"], c["value"])
        scored.append({**c, "score": sc, "hits": hits, "context": snippet})

    scored.sort(key=lambda x: x["score"], reverse=True)
    if not scored:
        return None, [], ["NO_ADDRESS_FOUND"]

    top = scored[0]
    runner = scored[1] if len(scored) > 1 else None

    THRESH = 10
    SEP = 4

    flags = []
    if top["score"] < THRESH:
        flags.append("NO_ADDRESS_FOUND")
        return None, scored[:12], flags

    if runner and (top["score"] - runner["score"]) < SEP:
        flags.append("AMBIGUOUS_ADDRESS")
        return None, scored[:12], flags

    return top["value"], scored[:12], flags

def parse_metadata(text: str):
    t = text or ""
    low = t.lower()

    out = {
      "recorded_date": None,
      "instrument_type": None,
      "book": None,
      "page": None,
      "doc_id": None,
      "consideration": None,
      "grantors": [],
      "grantees": [],
      "flags": []
    }

    m = re.search(r"\b(?:recorded|recording date)\s*[:\-]?\s*(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})\b", t, re.I)
    if not m:
        m = re.search(r"\b(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})\b", t)
    if m:
        mm, dd, yy = m.group(1).zfill(2), m.group(2).zfill(2), m.group(3)
        if len(yy) == 2: yy = "20" + yy
        out["recorded_date"] = f"{yy}-{mm}-{dd}"
    else:
        out["flags"].append("NO_RECORDED_DATE")

    if "quitclaim" in low or "quit claim" in low:
        out["instrument_type"] = "QUITCLAIM_DEED"
    elif "warranty deed" in low:
        out["instrument_type"] = "WARRANTY_DEED"
    elif "deed" in low:
        out["instrument_type"] = "DEED"
    else:
        out["flags"].append("NO_INSTRUMENT_TYPE")

    m = re.search(r"\bbook\s*[:#]?\s*(\d{1,8})\b[\s\S]{0,120}\bpage\s*[:#]?\s*(\d{1,8})\b", t, re.I)
    if m:
        out["book"], out["page"] = m.group(1), m.group(2)
    else:
        out["flags"].append("NO_BOOK_PAGE")

    m = re.search(r"\b(?:doc(?:ument)?\s*(?:id|no\.?|number)|instrument\s*(?:no\.?|number))\s*[:#]?\s*([A-Z0-9\-]{6,})\b", t, re.I)
    if m:
        out["doc_id"] = m.group(1)

    m = re.search(r"\b(?:consideration|amount)\s*[:\-]?\s*\$?\s*([0-9][0-9,]*)(?:\.\d{2})?\b", t, re.I)
    if not m:
        m = re.search(r"\$\s*([0-9][0-9,]*)(?:\.\d{2})?\b", t)
    if m:
        out["consideration"] = m.group(1).replace(",", "")
    else:
        out["flags"].append("NO_CONSIDERATION")

    return out

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--rawDir", required=True)
    ap.add_argument("--manifest", required=True)
    ap.add_argument("--outExtracted", required=True)
    ap.add_argument("--outErrors", required=True)
    ap.add_argument("--outAudit", required=True)
    ap.add_argument("--max", type=int, default=0)
    ap.add_argument("--pageLimit", type=int, default=2)
    ap.add_argument("--dpi", type=int, default=300)
    ap.add_argument("--psm", type=int, default=6)
    ap.add_argument("--oem", type=int, default=1)
    args = ap.parse_args()

    with open(args.manifest, "r", encoding="utf-8-sig") as f:
        manifest = json.load(f)
    file_hash = { x["file"]: x["sha256"] for x in manifest.get("files", []) }

    pdfs = [f for f in os.listdir(args.rawDir) if f.lower().endswith(".pdf")]
    pdfs.sort()
    if args.max and args.max > 0:
        pdfs = pdfs[:args.max]

    os.makedirs(os.path.dirname(args.outExtracted), exist_ok=True)
    os.makedirs(os.path.dirname(args.outErrors), exist_ok=True)
    os.makedirs(os.path.dirname(args.outAudit), exist_ok=True)

    out_ok = open(args.outExtracted, "w", encoding="utf-8")
    out_err = open(args.outErrors, "w", encoding="utf-8")

    audit = {
      "created_at": datetime.datetime.now(timezone.utc).isoformat().replace("+00:00","Z"),
      "raw_dir": args.rawDir,
      "pdfs_seen": len(pdfs),
      "extracted_ok": 0,
      "errors": 0,
      "ocr_page_limit": args.pageLimit,
      "ocr_dpi": args.dpi,
      "tesseract_config": f"--oem {args.oem} --psm {args.psm}",
      "missing_rates": {},
      "examples_errors": []
    }

    miss_counts = {"NO_PROPERTY_ADDRESS":0, "AMBIGUOUS_ADDRESS":0, "NO_BOOK_PAGE":0, "NO_RECORDED_DATE":0}
    config = f"--oem {args.oem} --psm {args.psm}"

    for i, fn in enumerate(pdfs, start=1):
      p = os.path.join(args.rawDir, fn)
      try:
        merged, blocks, total_len = ocr_regions(p, args.pageLimit, args.dpi, config)
        meta = parse_metadata(merged)

        cands = find_address_candidates(merged)
        prop_addr, scored, addr_flags = choose_property_address(merged, cands)

        extracted = {
          **meta,
          "property_address_raw": prop_addr,
          "property_address_norm": norm_addr(prop_addr) if prop_addr else None,
          "address_candidates": scored
        }

        flags = list(meta.get("flags", []))
        if "NO_BOOK_PAGE" in flags: miss_counts["NO_BOOK_PAGE"] += 1
        if "NO_RECORDED_DATE" in flags: miss_counts["NO_RECORDED_DATE"] += 1
        if "NO_ADDRESS_FOUND" in addr_flags:
            flags.append("NO_PROPERTY_ADDRESS")
            miss_counts["NO_PROPERTY_ADDRESS"] += 1
        if "AMBIGUOUS_ADDRESS" in addr_flags:
            flags.append("AMBIGUOUS_ADDRESS")
            miss_counts["AMBIGUOUS_ADDRESS"] += 1

        extracted["flags"] = flags

        rec = {
          "doc_type": "DEED",
          "source": {
            "file": fn,
            "rel_path": "publicData/registry/raw_pdfs/deeds/" + fn,
            "sha256": file_hash.get(fn),
            "extract_method": "ocr_candidates_scored_v4",
            "ocr_page_limit": args.pageLimit,
            "ocr_dpi": args.dpi,
            "tesseract_config": config,
            "ocr_text_total_len": total_len,
            "ocr_text_fingerprint": sha1(merged[:2000])
          },
          "extracted": extracted
        }

        out_ok.write(json.dumps(rec, ensure_ascii=False) + "\n")
        audit["extracted_ok"] += 1

        if i % 200 == 0:
          print(f"[progress] {i}/{len(pdfs)}")

      except Exception as e:
        audit["errors"] += 1
        err_rec = {"file": fn, "rel_path": "publicData/registry/raw_pdfs/deeds/" + fn, "error": str(e)[:900]}
        out_err.write(json.dumps(err_rec, ensure_ascii=False) + "\n")
        if len(audit["examples_errors"]) < 10:
          audit["examples_errors"].append(err_rec)

    out_ok.close()
    out_err.close()

    total = max(1, audit["extracted_ok"])
    audit["missing_rates"] = { k: round(v/total, 4) for k,v in miss_counts.items() }

    with open(args.outAudit, "w", encoding="utf-8") as f:
      json.dump(audit, f, indent=2)

if __name__ == "__main__":
    main()

