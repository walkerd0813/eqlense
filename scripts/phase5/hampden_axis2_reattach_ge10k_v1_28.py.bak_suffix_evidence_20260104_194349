import json, re
from collections import defaultdict, Counter
from datetime import datetime, timezone

def norm_ws(s): return re.sub(r"\s+", " ", (s or "").strip())
def up(s): return norm_ws(s).upper()

DIR_TOKENS = {"N","S","E","W","NE","NW","SE","SW","NORTH","SOUTH","EAST","WEST"}

# IMPORTANT: THIS MAP OUTPUTS SPINE DIALECT (short suffixes)
SUF_TO_SPINE = {
  "STREET":"ST","ST":"ST","ST.":"ST",
  "AVENUE":"AV","AVE":"AV","AV":"AV","AV.":"AV","AVE.":"AV",
  "ROAD":"RD","RD":"RD","RD.":"RD",
  "DRIVE":"DR","DR":"DR","DR.":"DR",
  "LANE":"LN","LN":"LN","LN.":"LN",
  "BOULEVARD":"BL","BLVD":"BL","BLVD.":"BL","BL":"BL",
  "PARKWAY":"PW","PKWY":"PW","PKWY.":"PW","PW":"PW",
  "TERRACE":"TE","TERR":"TE","TER":"TE","TE":"TE",
  "CIRCLE":"CR","CIR":"CR","CR":"CR",
  "HILL":"HL","HL":"HL",
  "COURT":"CT","CT":"CT",
  "PLACE":"PL","PL":"PL",
  "WAY":"WY","WY":"WY",
  "EXTENSION":"EXTN","EXTN":"EXTN","EXT":"EXTN",
}

def collapse_runs(s):
  # MELWOOOD -> MELWOOD
  return re.sub(r"([A-Z])\1{2,}", r"\1\1", s)

def split_tokens(s):
  return [t for t in re.split(r"[^A-Z0-9#]+", up(s)) if t]

def normalize_unit_from_tokens(toks):
  """
  Broad unit handling:
  - 'UNIT 305' / 'APT 3' / 'STE 2A'
  - '#305'
  - trailing single token sometimes used as unit (rare; we won't guess that)
  """
  unit=None
  out=[]
  i=0
  while i<len(toks):
    t=toks[i]
    if t in ("UNIT","APT","APARTMENT","STE","SUITE","#"):
      if i+1<len(toks):
        unit=toks[i+1].lstrip("#")
        i+=2
        continue
    if t.startswith("#") and len(t)>1:
      unit=t[1:]
      i+=1
      continue
    out.append(t)
    i+=1
  return out, unit

def norm_suffix(tok: str) -> str:
  tok = (tok or "").strip().upper().replace(".", "")
  return SUF_TO_SPINE.get(tok, tok)


def canonicalize_addr_to_spine_dialect(addr_raw):
  """
  Returns dict with:
  num, street (spine dialect), full, base (no suffix), unit
  """
  s=collapse_runs(up(addr_raw))
  toks=split_tokens(s)

  num=None
  rest=[]
  for t in toks:
    if num is None and t.isdigit():
      num=t
      continue
    rest.append(t)

  # strip directionals (match-first)
  rest=[t for t in rest if t not in DIR_TOKENS]

  # pull unit
  rest, unit = normalize_unit_from_tokens(rest)

  # normalize last token if it is an alpha suffix
  if rest and rest[-1].isalpha():
    rest[-1]=norm_suffix(rest[-1])

  street=" ".join(rest).strip() if rest else None
  full=(num+" "+street) if num and street else None

  base=None
  if rest:
    base_tokens=rest[:-1] if (rest and rest[-1].isalpha()) else rest
    base=" ".join(base_tokens).strip() if base_tokens else None

  return {"num":num,"street":street,"full":full,"base":base,"unit":unit}

def spine_get_town(r):
  # your spine definitely has "town", but keep resilient
  for k in ("town","city","municipality","jurisdiction_name","site_city","addr_city"):
    v=r.get(k)
    if isinstance(v,str) and v.strip():
      return up(v)
  return None

def spine_get_unit(r):
  for k in ("unit","addr_unit","unit_no","unit_number","apt","apartment","suite"):
    v=r.get(k)
    if isinstance(v,str) and v.strip():
      return up(v)
  return None

def build_spine_indexes(spine_path, towns_needed):
  idx_full = defaultdict(list)       # (town, full) -> [pid...]
  idx_full_unit = defaultdict(list)  # (town, full, unit) -> [pid...]
  idx_nosuf = defaultdict(list)      # (town, num, base) -> [pid...]

  debug = Counter()
  scanned=0
  kept=0
  town_skip=0

  with open(spine_path,"r",encoding="utf-8") as f:
    for line in f:
      if not line.strip():
        continue
      scanned += 1
      r = json.loads(line)
      town = (r.get('town') or r.get('jurisdiction_name') or r.get('jurisdiction') or '').strip().upper()
      if not town:
        continue
      # --- PATCH: do not inherit prior attachment state from hydrated input ---
      if isinstance(r.get('attach'), dict):
        r['attach_prev'] = r.get('attach')
      for _k in ('attach','attach_scope','attach_status','attachments_n'):
        if _k in r:
          try:
            del r[_k]
          except Exception:
            pass

      if town not in towns_needed:
        town_skip += 1
        continue

      pid = r.get("property_id")
      if not pid:
        debug["no_pid"] += 1
        continue

      # Prefer structured fields
      sn = r.get("street_no")
      st = r.get("street_name")

      if isinstance(sn,(int,float)):
        sn=str(int(sn))
      if isinstance(sn,str):
        sn=sn.strip()

      if isinstance(st,str) and st.strip() and sn:
        st_canon = canonicalize_addr_to_spine_dialect("0 "+st)["street"]  # trick: reuse suffix canonicalizer
        full = f"{sn} {st_canon}".strip()
        idx_full[(town, full)].append(pid)

        u = spine_get_unit(r)
        if u:
          idx_full_unit[(town, full, u)].append(pid)

        base = canonicalize_addr_to_spine_dialect(full)["base"]
        if base:
          idx_nosuf[(town, sn, base)].append(pid)

        kept += 1
        continue

      # Fallback to full_address if structured missing
      fa = r.get("full_address")
      if isinstance(fa,str) and fa.strip():
        k = canonicalize_addr_to_spine_dialect(fa)
        if k["full"]:
          idx_full[(town, k["full"])].append(pid)
          u=spine_get_unit(r)
          if u:
            idx_full_unit[(town, k["full"], u)].append(pid)
          if k["num"] and k["base"]:
            idx_nosuf[(town, k["num"], k["base"])].append(pid)
          kept += 1
        else:
          debug["no_full_from_fa"] += 1
      else:
        debug["no_addr_fields"] += 1

  return idx_full, idx_full_unit, idx_nosuf, {"scanned":scanned,"kept":kept,"town_skip":town_skip,"debug":dict(debug)}

def read_events(events_path):
  rows=[]
  towns=set()
  with open(events_path,"r",encoding="utf-8") as f:
    for line in f:
      if not line.strip(): continue
      r=json.loads(line)
      rows.append(r)
      t=r.get("town")
      if isinstance(t,str) and t.strip():
        towns.add(up(t))
  return rows, towns

def try_attach_single(town, addr_raw, idx_full, idx_full_unit, idx_nosuf):
  k = canonicalize_addr_to_spine_dialect(addr_raw)
  if not k["num"]:
    return ("UNKNOWN","no_num",None,"NO_NUM",k)

  # 1) full exact
  hits = idx_full.get((town, k["full"]), [])
  if len(hits)==1:
    return ("ATTACHED_A","AXIS2_FULL_ADDRESS_EXACT",hits[0],"NONE",k)
  if len(hits)>1:
    return ("UNKNOWN","collision",None,"COLLISION",k)

  # 2) unit exact if unit present
  if k["unit"]:
    u = up(k["unit"])
    hitsu = idx_full_unit.get((town, k["full"], u), [])
    if len(hitsu)==1:
      return ("ATTACHED_A","AXIS2_STREET+UNIT_EXACT",hitsu[0],"NONE",k)
    if len(hitsu)>1:
      return ("UNKNOWN","collision",None,"COLLISION",k)

  # 3) nosuf unique
  if k["base"]:
    hitsb = idx_nosuf.get((town, k["num"], k["base"]), [])
    if len(hitsb)==1:
      return ("ATTACHED_A","AXIS2_STREET_UNIQUE_NOSUF",hitsb[0],"NONE",k)
    if len(hitsb)>1:
      return ("UNKNOWN","collision",None,"COLLISION",k)

  return ("UNKNOWN","no_match",None,"NO_MATCH",k)

def main():
  import argparse
  ap=argparse.ArgumentParser()
  ap.add_argument("--events", required=True)
  ap.add_argument("--spine", required=True)
  ap.add_argument("--out", required=True)
  ap.add_argument("--audit", required=True)
  ap.add_argument("--debug_first_nomatch", type=int, default=25)
  args=ap.parse_args()

  t0=datetime.now(timezone.utc)

  events, towns_needed = read_events(args.events)
  print("=== AXIS2 REATTACH (>=10k) v1_28 (single canonical spine dialect + debug) ===")
  print("[info] events:", args.events)
  print("[info] spine :", args.spine)
  print("[info] events rows:", len(events), "towns_needed:", len(towns_needed))

  idx_full, idx_full_unit, idx_nosuf, idxmeta = build_spine_indexes(args.spine, towns_needed)
  print("[ok] spine index built full=", len(idx_full), "unit=", len(idx_full_unit), "nosuf=", len(idx_nosuf), "meta=", idxmeta)

  stats=Counter()
  debug_nomatch_printed=0

  with open(args.out,"w",encoding="utf-8") as fo:
    for r in events:
      town = up(r.get("town",""))
      addr = r.get("addr","") or ""
      if not town or not isinstance(addr,str):
        # keep behavior: if malformed, mark unknown
        out = dict(r)
        out.update({
          "attach_scope": (r.get("attach_scope") or r.get("attach") or {}).get("attach_scope","SINGLE"),
          "attach_status": "UNKNOWN",
          "match_method": "bad_row",
          "why": "BAD_ROW",
          "attachments_n": int((r.get("attach") or {}).get("attachments_n") or 0),
        })
        fo.write(json.dumps(out, ensure_ascii=False) + "\n")
        stats["still_unknown"] += 1
        continue

      st, mm, pid, why, k = try_attach_single(town, addr, idx_full, idx_full_unit, idx_nosuf)

      out = dict(r)
      out.update({
        "attach_scope": "SINGLE" if int((r.get("attach") or {}).get("attachments_n") or 0) <= 1 else "MULTI",
        "attach_status": st,
        "match_method": mm,
        "why": why,
        "attachments_n": int((r.get("attach") or {}).get("attachments_n") or 0),
      })
      if pid:
        out["property_id"] = pid

      fo.write(json.dumps(out, ensure_ascii=False) + "\n")

      if st=="ATTACHED_A":
        stats["attached_a"] += 1
      else:
        stats["still_unknown"] += 1
        if mm=="no_match" and debug_nomatch_printed < args.debug_first_nomatch:
          debug_nomatch_printed += 1
          fk=(town, k["full"])
          nk=(town, k["num"], k["base"])
          print("\n[debug NO_MATCH]", debug_nomatch_printed)
          print(" raw:", town, "|", addr)
          print(" canon:", k)
          print(" full_key:", fk, "exists:", fk in idx_full, "hit_n:", len(idx_full.get(fk,[])))
          print(" nosuf_key:", nk, "exists:", nk in idx_nosuf, "hit_n:", len(idx_nosuf.get(nk,[])))
          if k["unit"]:
            uk=(town, k["full"], up(k["unit"]))
            print(" unit_key:", uk, "exists:", uk in idx_full_unit, "hit_n:", len(idx_full_unit.get(uk,[])))

  t1=datetime.now(timezone.utc)
  audit={
    "created_at": t1.isoformat(),
    "events": args.events,
    "spine": args.spine,
    "out": args.out,
    "stats": dict(stats),
    "elapsed_s": round((t1-t0).total_seconds(), 2),
    "idx_meta": idxmeta,
  }
  with open(args.audit,"w",encoding="utf-8") as fa:
    json.dump(audit, fa, indent=2)

  print("[done] wrote out_rows=", len(events), "stats=", dict(stats), "audit=", args.audit)

if __name__=="__main__":
  main()
