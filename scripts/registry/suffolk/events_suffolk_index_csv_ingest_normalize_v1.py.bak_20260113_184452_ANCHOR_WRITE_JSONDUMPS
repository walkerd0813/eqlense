#!/usr/bin/env python
# events_suffolk_index_csv_ingest_normalize_v1.py
# Purpose: Ingest Suffolk registry index CSV (mixed doc types), normalize to canonical event schema,
# split into streams, and emit audit. Deterministic + evidence-first. No attach logic here.

import argparse, csv, json, os, re, sys, hashlib

def build_event_id(row: dict) -> str:
    """
    Deterministic doc-level event id for Suffolk index CSV normalization.
    Uses only stable fields present in the index export.
    """
    county = (row.get("county") or "").strip().lower()
    rec = row.get("recording") or {}
    doc = row.get("document") or {}
    pref = row.get("property_ref") or {}

    key_parts = [
        "ma", "registry", "index",
        county,
        str((rec.get("office") or "")).strip().upper(),
        str((rec.get("recording_date") or "")).strip(),
        str((rec.get("book") or "")).strip(),
        str((rec.get("page") or "")).strip(),
        str((rec.get("document_number") or "")).strip(),
        str((doc.get("descr_norm") or doc.get("descr_raw") or "")).strip().upper(),
        str((pref.get("town_code") or "")).strip().upper(),
        str((pref.get("address_norm") or pref.get("address_raw") or "")).strip().upper(),
    ]
    doc_key = "|".join(key_parts)
    h = hashlib.sha1(doc_key.encode("utf-8")).hexdigest()
    return "MA|registry|index|" + county + "|" + h
from datetime import datetime

ABBREV_MAP = {
  # common street type expansions
  "ST": "STREET", "ST.": "STREET",
  "AVE": "AVENUE", "AVE.": "AVENUE",
  "RD": "ROAD", "RD.": "ROAD",
  "DR": "DRIVE", "DR.": "DRIVE",
  "BLVD": "BOULEVARD", "BLVD.": "BOULEVARD",
  "CT": "COURT", "CT.": "COURT",
  "PL": "PLACE", "PL.": "PLACE",
  "TER": "TERRACE", "TER.": "TERRACE",
  "CIR": "CIRCLE", "CIR.": "CIRCLE",
  "HWY": "HIGHWAY",
  # the one you explicitly called out
  "PK": "PARK", "PK.": "PARK",
}

UNIT_TOKENS = {"UNIT", "APT", "APARTMENT", "PH", "STE", "SUITE", "#"}

def sha256_file(path: str) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def norm_ws(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip())

def norm_upper(s: str) -> str:
    return norm_ws(s).upper()

def normalize_street_tokens(tokens):
    out = []
    for t in tokens:
        tt = t.strip().upper()
        if not tt:
            continue
        out.append(ABBREV_MAP.get(tt, tt))
    return out

def extract_unit_from_text(s: str):
    """
    Pull unit markers like 'UNIT 407', 'APT 2', '#5', 'STE 12' from a freeform string.
    Returns (unit_norm, residue_without_unit).
    """
    raw = norm_upper(s)
    if not raw:
        return None, ""

    # normalize separators
    raw2 = raw.replace(",", " ").replace("  ", " ")
    # handle '#5' patterns
    m = re.search(r"(?:\s|^)\#\s*([A-Z0-9\-]+)\s*$", raw2)
    if m:
        unit = m.group(1)
        residue = re.sub(r"(?:\s|^)\#\s*[A-Z0-9\-]+\s*$", "", raw2).strip()
        return unit, residue

    # handle 'UNIT 407' / 'APT 2' etc anywhere near end
    m = re.search(r"(?:\s|^)(UNIT|APT|APARTMENT|STE|SUITE|PH)\s+([A-Z0-9\-]+)\s*$", raw2)
    if m:
        unit = f"{m.group(1)} {m.group(2)}"
        residue = re.sub(r"(?:\s|^)(UNIT|APT|APARTMENT|STE|SUITE|PH)\s+[A-Z0-9\-]+\s*$", "", raw2).strip()
        return unit, residue

    return None, raw2.strip()

def build_address(str_num: str, str_name: str, prop_desc: str):
    """
    Produces:
      address.raw_line
      address.number_raw
      address.street_raw
      address.unit_raw (best-effort)
      address.street_norm (abbrev-expanded)
      address.unit_norm
      address.full_norm
      evidence.flags
    """
    flags = []
    num_raw = norm_ws(str_num)
    street_raw = norm_ws(str_name)
    prop_raw = norm_ws(prop_desc)

    unit_norm = None
    street_work = street_raw

    # primary unit extraction from str_name (where we see "W BROADWAY UNIT 407")
    u1, residue1 = extract_unit_from_text(street_work)
    if u1:
        unit_norm = u1
        street_work = residue1
        flags.append("UNIT_FROM_STR_NAME")

    # secondary: sometimes prop_desc contains unit-ish info (less common, but safe)
    if not unit_norm and prop_raw:
        u2, _ = extract_unit_from_text(prop_raw)
        if u2:
            unit_norm = u2
            flags.append("UNIT_FROM_PROP_DESC")

    # normalize street tokens (expand PK -> PARK, etc)
    street_tokens = [t for t in re.split(r"\s+", norm_upper(street_work)) if t]
    street_tokens_norm = normalize_street_tokens(street_tokens)
    street_norm = " ".join(street_tokens_norm).strip()

    # build full_norm
    parts = []
    if num_raw:
        parts.append(norm_upper(num_raw))
    if street_norm:
        parts.append(street_norm)
    if unit_norm:
        parts.append(unit_norm)  # keep token like "UNIT 407" as a part
    full_norm = " ".join(parts).strip()

    raw_line = " ".join([p for p in [num_raw, street_raw] if p]).strip()

    return {
        "raw_line": raw_line or None,
        "number_raw": num_raw or None,
        "street_raw": street_raw or None,
        "prop_desc_raw": prop_raw or None,
        "street_norm": street_norm or None,
        "unit_norm": unit_norm or None,
        "full_norm": full_norm or None,
        "flags": flags,
    }

def classify_event_type(descr: str) -> str:
    d = norm_upper(descr)

    # Order matters: more specific first
    if "LIS PENDENS" in d or "LIS PEND" in d:
        return "LIS_PENDENS"
    if "TAX LIEN" in d or "LIEN" in d:
        return "LIEN"
    if "ASSIGN" in d:
        return "ASSIGNMENT"
    if "DISCHARGE" in d or "RELEASE" in d or "SATISFACTION" in d:
        return "RELEASE"
    if "MORTGAGE" in d:
        return "MORTGAGE"
    if "DEED" in d:
        return "DEED"

    return "OTHER"

def parse_date_mmddyyyy(s: str):
    s2 = (s or "").strip()
    if not s2:
        return None
    for fmt in ("%m/%d/%Y", "%m/%d/%y"):
        try:
            return datetime.strptime(s2, fmt).date().isoformat()
        except Exception:
            pass
    return None

def safe_float(s: str):
    try:
        t = (s or "").strip().replace(",", "")
        if t == "":
            return None
        return float(t)
    except Exception:
        return None

def write_ndjson(path: str, rows):
    with open(path, "w", encoding="utf-8") as f:
        for r in rows:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--infile", required=True, help="Path to Suffolk CSV file")
    ap.add_argument("--outdir", required=True, help="Output directory (run workdir)")
    ap.add_argument("--county", default="suffolk")
    ap.add_argument("--source_system", default="registry_index_csv")
    args = ap.parse_args()

    infile = args.infile
    outdir = args.outdir
    os.makedirs(outdir, exist_ok=True)

    audit = {
        "engine_id": "events.suffolk_index_csv_ingest_normalize_v1",
        "infile": os.path.abspath(infile),
        "csv_sha256": sha256_file(infile),
        "rows_total": 0,
        "rows_by_event_type": {},
        "unknown_descr_values": {},
        "missing_required_fields": 0,
        "header_seen": None,
        "created_at": datetime.utcnow().isoformat() + "Z",
    }

    # Outputs collected in memory in v1 (fine); can stream later if needed.
    all_rows = []
    streams = {
        "DEED": [],
        "MORTGAGE": [],
        "ASSIGNMENT": [],
        "RELEASE": [],
        "LIEN": [],
        "LIS_PENDENS": [],
        "OTHER": [],
    }

    required_cols = ["office","date","descr","doc_num","volm","page","party","name_last","name_first","consideration","str_num","str_name","prop_desc","town_code"]

    with open(infile, "r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        audit["header_seen"] = reader.fieldnames

        # basic header gate (we don't crash, but we record)
        missing = [c for c in required_cols if c not in (reader.fieldnames or [])]
        if missing:
            audit["missing_required_columns"] = missing

        for row in reader:
            audit["rows_total"] += 1

            office = norm_upper(row.get("office"))
            date_raw = row.get("date")
            descr = row.get("descr")
            doc_num = norm_ws(row.get("doc_num"))
            volm = norm_ws(row.get("volm"))   # registry book (called volm in this file)
            page = norm_ws(row.get("page"))
            party = norm_upper(row.get("party"))
            name_last = norm_ws(row.get("name_last"))
            name_first = norm_ws(row.get("name_first"))
            consideration_raw = row.get("consideration")
            str_num = row.get("str_num")
            str_name = row.get("str_name")
            prop_desc = row.get("prop_desc")
            town_code = norm_upper(row.get("town_code"))

            event_type = classify_event_type(descr)
            audit["rows_by_event_type"][event_type] = audit["rows_by_event_type"].get(event_type, 0) + 1

            # Track unknown descr strings for mapping hardening
            d_norm = norm_upper(descr)
            if event_type == "OTHER":
                audit["unknown_descr_values"][d_norm] = audit["unknown_descr_values"].get(d_norm, 0) + 1

            recording_date = parse_date_mmddyyyy(date_raw)
            consideration_amt = safe_float(consideration_raw)

            addr = build_address(str_num, str_name, prop_desc)

            # Evidence-first: keep raw + normalized + flags
            evidence = {
                "source_system": args.source_system,
                "office": office or None,
                "descr_raw": descr,
                "descr_norm": d_norm or None,
                "book_raw": volm or None,
                "page_raw": page or None,
                "doc_num_raw": doc_num or None,
                "party_raw": party or None,
                "address_flags": addr.get("flags", []),
                "field_map": {"volm":"book"},
            }

            # Canonical-ish event record (registry-index-derived)
            # NOTE: attachment is separate phase; we keep property_id null here.
            ev = {
                "event_id": None,  # filled deterministically downstream if desired
                "event_type": event_type,
                "county": args.county,
                "source": {
                    "system": args.source_system,
                    "file_sha256": audit["csv_sha256"],
                },
                "recording": {
                    "recording_date_raw": date_raw,
                    "recording_date": recording_date,
                    "book": volm or None,          # canonical name is book
                    "page": page or None,
                    "document_number": doc_num or None,
                    "office": office or None,
                },
                "document": {
                    "descr_raw": descr,
                    "descr_norm": d_norm or None,
                },
                "parties": [{
                    "role": party or None,
                    "name_last": name_last or None,
                    "name_first": name_first or None,
                }],
                "consideration": {
                    "raw_text": (consideration_raw.strip() if isinstance(consideration_raw, str) else str(consideration_raw) if consideration_raw is not None else None),
                    "amount": consideration_amt,
                },
                "property_ref": {
                    "town_code": town_code or None,
                    "address_raw": addr.get("raw_line"),
                    "address_norm": addr.get("full_norm"),
                    "prop_desc_raw": addr.get("prop_desc_raw"),
                },
                "meta": {
                    "schema_version": "registry_event_v0_1",
                    "ingested_at": datetime.utcnow().isoformat() + "Z",
                },
                "evidence": evidence,
            }

            # Minimal required fields gate tracking
            if not town_code or not addr.get("full_norm"):
                audit["missing_required_fields"] += 1
                ev["meta"]["missing_key_fields"] = True

            all_rows.append(ev)
            streams[event_type].append(ev)

    # Write outputs
    out_all = os.path.join(outdir, "events__ALL.ndjson")
    write_ndjson(out_all, all_rows)

    out_streams = {}
    for k, rows in streams.items():
        p = os.path.join(outdir, f"events__{k}.ndjson")
        write_ndjson(p, rows)
        out_streams[k] = p

    audit["out_all"] = out_all
    audit["out_streams"] = out_streams

    audit_path = os.path.join(outdir, "audit.json")
    with open(audit_path, "w", encoding="utf-8") as f:
        json.dump(audit, f, indent=2)

    print("[done] normalize v1")
    print(f"[rows_total] {audit['rows_total']}")
    print(f"[missing_required_fields] {audit['missing_required_fields']}")
    print(f"[out_all] {out_all}")
    print(f"[audit] {audit_path}")

if __name__ == "__main__":
    main()

