param(
  [Parameter(Mandatory=$true)][string]$Root,
  [Parameter(Mandatory=$true)][string]$PdfDir
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

# ---- Validate inputs ----
if (-not (Test-Path $Root))   { throw "Root not found: $Root" }
if (-not (Test-Path $PdfDir)) { throw "PdfDir not found: $PdfDir" }

$invPy = Join-Path $Root "scripts\registry\otr\otr_inventory_hampden_v1.py"
$extPy = Join-Path $Root "scripts\registry\otr\otr_extract_hampden_v1.py"
if (-not (Test-Path $invPy)) { throw "Missing: $invPy" }
if (-not (Test-Path $extPy)) { throw "Missing: $extPy" }

$workDir = Join-Path $Root "publicData\registry\hampden\_work\OTR_EXTRACT_ALLDOCS_v1"
New-Item -ItemType Directory -Force -Path $workDir | Out-Null

$ts = Get-Date -Format "yyyyMMdd_HHmmss"
$outInventory = Join-Path $workDir ("inventory__hampden_otr__{0}.json" -f $ts)
$outEvents    = Join-Path $workDir ("events__HAMPDEN__OTR__RAW__{0}.ndjson" -f $ts)
$outQuar      = Join-Path $workDir ("quarantine__HAMPDEN__OTR__RAW__{0}.ndjson" -f $ts)
$auditInv     = Join-Path $workDir ("otr_inventory__audit__v1__{0}.json" -f $ts)
$auditExt     = Join-Path $workDir ("otr_extract__audit__v1__{0}.json" -f $ts)

Write-Host "[run] input dir: $PdfDir"
Write-Host "[run] work dir : $workDir"

# ---- Inventory ----
Write-Host "[run] inventory -> $outInventory"
python $invPy --in_dir $PdfDir --out_inventory $outInventory --audit $auditInv

# ---- Extract ----
Write-Host "[run] extract -> $outEvents"
python $extPy --in_dir $PdfDir --out_events $outEvents --out_quarantine $outQuar --audit $auditExt --county hampden

Write-Host "[done] inventory: $outInventory"
Write-Host "[done] events   : $outEvents"
Write-Host "[done] quar     : $outQuar"
Write-Host "[done] audits   : $auditInv ; $auditExt"

# ---- AUTO_SET_OUTEVENTS (safe) ----
# Ensure outEvents points at the newest extractor output in the work dir (in case external callers rely on it)
try {
  $latest = Get-ChildItem -Path $workDir -Filter "events__HAMPDEN__OTR__RAW__*.ndjson" -ErrorAction SilentlyContinue |
    Sort-Object LastWriteTime -Descending | Select-Object -First 1
  if ($latest -and ($outEvents -ne $latest.FullName)) {
    Write-Host "[auto] outEvents -> $($latest.FullName)"
    $outEvents = $latest.FullName
  }
} catch {}

# ---- POSTFIX_DOCTYPES_AUTORUN ----
try {
  $postfixOutDir = Join-Path $workDir "_postfix_doctypes"
  New-Item -ItemType Directory -Force -Path $postfixOutDir | Out-Null

  $postfixPs = Join-Path $Root "scripts\registry\otr\Run-Hampden-OTR-Postfix-DocTypes-v1_PS51SAFE.ps1"
  if (Test-Path $postfixPs) {
    if ($outEvents -and (Test-Path $outEvents)) {
      Write-Host "[auto] postfix doctypes on $outEvents"
      powershell -NoProfile -ExecutionPolicy Bypass -File $postfixPs -InEvents $outEvents -OutDir $postfixOutDir
    } else {
      Write-Host "[auto] postfix skipped (outEvents missing)"
    }
  } else {
    Write-Host "[auto] postfix skipped (missing: $postfixPs)"
  }
} catch {
  Write-Host "[auto] postfix failed: $($_.Exception.Message)"
}
