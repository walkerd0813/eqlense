$root = (Get-Location).Path
param(
  [Parameter(Mandatory=$true)][string]$Root,
  [Parameter(Mandatory=$true)][string]$PdfDir
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

function NowStamp() { (Get-Date).ToString("yyyyMMdd_HHmmss") }

if (-not (Test-Path $Root))  { throw "Root not found: $Root" }
if (-not (Test-Path $PdfDir)) { throw "PdfDir not found: $PdfDir" }

$workBase = Join-Path $Root "publicData\registry\hampden\_work\OTR_EXTRACT_ALLDOCS_v1"
New-Item -ItemType Directory -Force -Path $workBase | Out-Null

$stamp = NowStamp

$invOut   = Join-Path $workBase ("inventory__hampden_otr__{0}.json" -f $stamp)
$invAudit = Join-Path $workBase ("otr_inventory__audit__v1__{0}.json" -f $stamp)

$evtOut   = Join-Path $workBase ("events__HAMPDEN__OTR__RAW__{0}.ndjson" -f $stamp)
$quarOut  = Join-Path $workBase ("quarantine__HAMPDEN__OTR__RAW__{0}.ndjson" -f $stamp)
$extAudit = Join-Path $workBase ("otr_extract__audit__v1__{0}.json" -f $stamp)

Write-Host ("[run] input dir: {0}" -f $PdfDir)
Write-Host ("[run] work dir : {0}" -f $workBase)

# Inventory
Write-Host ("[run] inventory -> {0}" -f $invOut)
python (Join-Path $Root "scripts\registry\otr\otr_inventory_hampden_v1.py") `
  --in_dir $PdfDir `
  --out_inventory $invOut `
  --audit $invAudit `
  --glob "*.pdf"

# Extract
Write-Host ("[run] extract -> {0}" -f $evtOut)
python (Join-Path $Root "scripts\registry\otr\otr_extract_hampden_v1.py") `
  --in_dir $PdfDir `
  --out_events $evtOut `
  --out_quarantine $quarOut `
  --audit $extAudit `
  --county "hampden"

Write-Host ("[done] inventory: {0}" -f $invOut)
Write-Host ("[done] events   : {0}" -f $evtOut)
Write-Host ("[done] quar     : {0}" -f $quarOut)
Write-Host ("[done] audits   : {0} ; {1}" -f $invAudit, $extAudit)


# --- AUTO_SET_OUTEVENTS_V3 ---
# Ensure $outEvents points at the newest extractor output in the work dir
try {
  if (-not $root) { $root = (Get-Location).Path }
  $workDirGuess = Join-Path $root 'publicData\registry\hampden\_work\OTR_EXTRACT_ALLDOCS_v1'
  if (Test-Path $workDirGuess) {
    $latest = Get-ChildItem -Path $workDirGuess -Filter 'events__HAMPDEN__OTR__RAW__*.ndjson' -ErrorAction SilentlyContinue |
      Sort-Object LastWriteTime -Descending | Select-Object -First 1
    if ($latest) {
      if (-not $outEvents -or -not (Test-Path $outEvents) -or ($outEvents -ne $latest.FullName)) {
        $outEvents = $latest.FullName
      }
    }
  }
} catch { }
# --- /AUTO_SET_OUTEVENTS_V3 ---

# --- POSTFIX_DOCTYPES_AUTORUN_V1 ---
try {
  if (-not $root) { $root = (Get-Location).Path }
  $postfixOutDir = Join-Path $root "publicData\registry\hampden\_work\OTR_EXTRACT_ALLDOCS_v1\_postfix_doctypes"
  New-Item -ItemType Directory -Force -Path $postfixOutDir | Out-Null

  if ($outEvents -and (Test-Path $outEvents)) {
    Write-Host "[auto] postfix doctypes on $outEvents"
    powershell -ExecutionPolicy Bypass -File ".\scripts\registry\otr\Run-Hampden-OTR-Postfix-DocTypes-v1_PS51SAFE.ps1" `
      -InEvents $outEvents `
      -OutDir $postfixOutDir
  } else {
    Write-Host "[auto] postfix doctypes skipped (could not find outEvents variable or file)"
  }
} catch {
  Write-Host "[auto][warn] postfix doctypes failed: $($_.Exception.Message)"
}
# --- /POSTFIX_DOCTYPES_AUTORUN_V1 ---
