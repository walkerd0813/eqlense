#!/usr/bin/env python3
"""
Hampden Registry index-PDF extractor (Recorded Land DEEDS only) â€” v1_0

Goal:
- Stream a (potentially huge) "RECORDED LAND DOCUMENTS" PDF that contains ONLY DEED rows
- Rebuild readable lines from rotated glyphs (pdfminer often marks these chars as upright=False)
- Reconstruct per-instrument event blocks:
    * header row fields: recorded datetime, inst#, grp-seq, book-page, ref book-page, consideration, doc_type
    * body: Town/Addr property refs (supports multi-property instruments)
    * parties: strict parsing of "1/2" group + "P/C" flag + name (no mixing company/person)

Outputs:
- NDJSON events (schema-ish compatible with registry_event_mim_v1_1)
- Quarantine NDJSON for bad/partial event blocks
- Audit JSON for run diagnostics

Usage:
  python scripts/_registry/hampden/extract_hampden_indexpdf_recorded_land_deeds_v1_1.py ^
      --pdf "C:\\path\\to\\RECORDED_LAND\\deeds.pdf" ^
      --out "C:\...\events__HAMPDEN__RECORDED_LAND__DEED__...ndjson" ^
      --audit "C:\...\audit__...json" ^
      --quarantine_dir "C:\...\quarantine" ^
      --start_page 0 --max_pages 0

Notes:
- This parser is intentionally strict + conservative. If it can't prove a field, it leaves it null and records a reason.
- It assumes the PDF is DEEDS-only (per your workflow). We still extract doc_type_raw per block and will quarantine if not DEED.
"""

from __future__ import annotations
import argparse, json, os, re, time, hashlib
from typing import Dict, Any, List, Optional, Tuple

import pdfplumber
def _extract_words_with_attrs(page):
    # Keep upright if available; try direction, but fall back if the PDF chars lack it.
    try:
        return page.extract_words(
            keep_blank_chars=False,
            use_text_flow=False,
            extra_attrs=['upright','direction'],
        )
    except KeyError:
        # Some PDFs don't provide 'direction' for chars in pdfplumber; fall back safely.
        return page.extract_words(
            keep_blank_chars=False,
            use_text_flow=False,
            extra_attrs=['upright'],
        )

def _score_words(words):
    # Score for 'normal' horizontal text + header tokens
    if not words:
        return 0
    header_set = {'RECORDED','LAND','DOCUMENTS','REGISTERED'}
    ltr = 0
    hdr = 0
    for w in words:
        t = (w.get('text') or '').strip()
        if not t:
            continue
        d = w.get('direction')
        up = w.get('upright', True)
        if up and (d is None or d == 'ltr'):
            ltr += 1
        if t.upper() in header_set:
            hdr += 1
    # header hits are strong evidence orientation is correct
    return (ltr * 1) + (hdr * 50) + int(len(words) * 0.01)

def _pick_best_orientation(page):
    """
    Choose best orientation for token extraction.
    IMPORTANT: pdfplumber Page.rotate is not available in some versions.
    We degrade safely to rot=0 when rotate is unavailable.
    Returns: (score, rot, page_obj, words)
    """
    best = (float("-inf"), 0, page, [])
    for rot in (0, 90, 270, 180):
        if rot == 0:
            p2 = page
        else:
            # Degrade safely if rotate doesn't exist on this pdfplumber.Page
            if hasattr(page, "rotate"):
                try:
                    p2 = page.rotate(rot)
                except Exception:
                    p2 = page
            else:
                p2 = page

        try:
            words = _extract_words_with_attrs(p2) or []
        except Exception:
            words = []
        try:
            score = _score_words(words)
        except Exception:
            score = float("-inf")

        # If we couldn't actually rotate (p2 == page for rot != 0), penalize non-zero rotations
        if rot != 0 and p2 is page:
            score -= 1000.0

        if score > best[0]:
            best = (score, rot, p2, words)

    return best  # (score, rot, page, words)

def _best_oriented_page(page):
    # Try rotations and pick the one that yields the most sane 'ltr/upright' words
    best = None
    for rot in (0, 90, 270, 180):
        p = page if rot == 0 else page.rotate(rot)
        words = _extract_words_with_attrs(p)
        score = _score_words(words)
        cand = (score, rot, p, words)
        if best is None or cand[0] > best[0]:
            best = cand
    return best  # (score, rot, page, words)

def _score_words(words):
    # Score for 'normal' horizontal text + header tokens
    if not words:
        return 0
    header_set = {'RECORDED','LAND','DOCUMENTS','REGISTERED'}
    ltr = 0
    hdr = 0
    for w in words:
        t = (w.get('text') or '').strip()
        if not t:
            continue
        d = w.get('direction')
        up = w.get('upright', True)
        if up and (d is None or d == 'ltr'):
            ltr += 1
        if t.upper() in header_set:
            hdr += 1
    # header hits are strong evidence orientation is correct
    return (ltr * 1) + (hdr * 50) + int(len(words) * 0.01)

def _best_oriented_page(page):
    # Try rotations and pick the one that yields the most sane 'ltr/upright' words
    best = None
    for rot in (0, 90, 270, 180):
        p = page if rot == 0 else page.rotate(rot)
        words = _extract_words_with_attrs(p)
        score = _score_words(words)
        cand = (score, rot, p, words)
        if best is None or cand[0] > best[0]:
            best = cand
    return best  # (score, rot, page, words)

RE_DASH = re.compile(r"-{10,}")
RE_TOWN = re.compile(r"^\s*Town:\s*(?P<town>.+?)\s+Addr:\s*(?P<addr>.+?)\s*$", re.I)
RE_PARTY = re.compile(r"^\s*(?P<group>[12])\s+(?P<pc>[PC])\s+(?P<name>.+?)\s*(?:Y\s*)?$", re.I)

def sha256_file(path: str) -> str:
    h=hashlib.sha256()
    with open(path,'rb') as f:
        for chunk in iter(lambda:f.read(1024*1024), b''):
            h.update(chunk)
    return h.hexdigest()

def normalize_digit_spacing(s: str) -> str:
    # Collapse "5 6 0 4 2" => "56042" without destroying normal words
    s = re.sub(r"(?<=\d)\s+(?=\d)", "", s)
    # Common: "2 4 7 3 4 - 7 9" => "24734-79"
    s = re.sub(r"(?<=\d)\s*-\s*(?=\d)", "-", s)
    # Common: "1 4 7 , 5 0 0 . 0 0" => "147,500.00"
    s = re.sub(r"(?<=\d)\s*,\s*(?=\d)", ",", s)
    s = re.sub(r"(?<=\d)\s*\.\s*(?=\d)", ".", s)
    return re.sub(r"\s+", " ", s).strip()

def clean_party_name(raw: str) -> str:
    raw = raw.strip()
    # remove known tail markers if they leak in
    raw = re.sub(r"\bFILE\b.*$", "", raw, flags=re.I).strip()
    raw = re.sub(r"\bDESCR/LOC/DELIVERED\b.*$", "", raw, flags=re.I).strip()
    raw = re.sub(r"\s+", " ", raw).strip()
    return raw

def transform_char(c: Dict[str,Any], page_width: float) -> Dict[str,Any]:
    """
    Convert rotated coordinate space into a stable "template" space.
    For these Hampden PDFs, glyphs are often rotated so pdfminer returns upright=False.
    Empirically, mapping:
      tx = top/bottom (y coords) , ty = page_width - x coords
    yields readable LTR lines.
    """
    x0 = float(c.get("top", 0.0))
    x1 = float(c.get("bottom", x0))
    y0 = float(page_width - float(c.get("x1", 0.0)))
    y1 = float(page_width - float(c.get("x0", 0.0)))
    return {**c, "tx0": x0, "tx1": x1, "ty0": y0, "ty1": y1}

def build_lines_from_chars(chars: List[Dict[str,Any]], *, y_tol: float = 1.0) -> List[Dict[str,Any]]:
    """
    Build physical lines by clustering on ty0 (y in template space), then sorting by tx0.
    Output line dicts:
      { y: float, text: str, chars: [ {text, tx0, tx1, ...}, ... ] }
    """
    if not chars:
        return []
    chars = [c for c in chars if (c.get("text") is not None)]
    chars = sorted(chars, key=lambda c: (c["ty0"], c["tx0"]))
    lines: List[Dict[str,Any]] = []
    for c in chars:
        if not lines or abs(c["ty0"] - lines[-1]["y"]) > y_tol:
            lines.append({"y": c["ty0"], "chars": [c]})
        else:
            lines[-1]["chars"].append(c)
    out=[]
    for ln in lines:
        ch = sorted(ln["chars"], key=lambda c: c["tx0"])
        txt = "".join(c.get("text","") for c in ch)
        # normalize whitespace for readability
        txt = re.sub(r"[ \t]+", " ", txt).strip()
        out.append({"y": ln["y"], "text": txt, "chars": ch})
    return out

def parse_event_header_line(line_text: str) -> Dict[str,Any]:
    """
    Parse the 'header row' line which includes:
      recorded datetime, inst#, grp-seq, book-page, ref-book-page, consideration, doc_type
    We rely on patterns rather than fixed columns because these PDFs often contain spaced digits.
    """
    s = normalize_digit_spacing(line_text)

    out = {
        "recorded_at_raw": None,
        "recording_date_raw": None,
        "recording_time_raw": None,
        "instrument_number_raw": None,
        "grp_seq_raw": None,
        "book_page_raw": None,
        "ref_book_page_raw": None,
        "doc_type_code_raw": None,
        "consideration_amount_raw": None,
    }

    # doc type (expect DEED for this extractor)
    m = re.search(r"\b(DEED)\b", s, re.I)
    if m:
        out["doc_type_code_raw"] = m.group(1).upper()

    # consideration: last money-looking token
    m = re.search(r"(?P<amt>\d{1,3}(?:,\d{3})*(?:\.\d{2})?)\s*$", s)
    if m:
        out["consideration_amount_raw"] = m.group("amt")

    # book-page patterns like 24734-79 appear 1-2 times
    bps = re.findall(r"\b(\d{4,7}-\d{1,6})\b", s)
    if bps:
        out["book_page_raw"] = bps[0]
        if len(bps) > 1:
            out["ref_book_page_raw"] = bps[1]

    # instrument: 4-7 digit; in Hampden samples it's 5 digits
    insts = re.findall(r"\b(\d{4,7})\b", s)
    # choose the one that isn't part of dates/times/amounts by heuristic:
    # - exclude year (4 digits starting with 19/20)
    inst_candidates=[x for x in insts if not (len(x)==4 and (x.startswith("19") or x.startswith("20")))]
    if inst_candidates:
        # often the first mid-line candidate is INST
        out["instrument_number_raw"] = inst_candidates[0]

    # grp-seq: usually a small integer near inst; if present as "1" etc
    m = re.search(r"\b" + (out["instrument_number_raw"] or r"\d{4,7}") + r"\s+(?P<gs>\d{1,4})\b", s)
    if m:
        out["grp_seq_raw"] = m.group("gs")

    # datetime: try to recover mm-dd-yyyy + time token
    m = re.search(r"(\d{2}-\d{2}-\d{4})\s+(\d{1,2}:\d{2}:\d{2}\s*[AP]M)", s, re.I)
    if m:
        out["recording_date_raw"] = m.group(1)
        out["recording_time_raw"] = re.sub(r"\s+", "", m.group(2).upper())
        out["recorded_at_raw"] = f"{out['recording_date_raw']} {out['recording_time_raw']}"

    return out

def parse_property_line(line_text: str) -> Optional[Dict[str,str]]:
    m = RE_TOWN.match(line_text)
    if not m:
        return None
    town = re.sub(r"\s+", " ", m.group("town").strip()).upper()
    addr = re.sub(r"\s+", " ", m.group("addr").strip()).upper()
    return {"town": town, "address_raw": addr}

def parse_party_line(line_text: str) -> Optional[Dict[str,Any]]:
    m = RE_PARTY.match(line_text)
    if not m:
        return None
    grp = int(m.group("group"))
    pc = m.group("pc").upper()
    nm = clean_party_name(m.group("name"))
    if not nm:
        return None
    return {
        "party_group": grp,
        "pc_flag": pc,
        "name_raw": nm,
    }

def pc_to_entity_type(pc: str) -> str:
    return "person" if pc == "P" else "company"

def group_to_role(event_type: str, grp: int) -> str:
    # DEED mapping (locked-in for this extractor)
    if event_type == "DEED":
        return "GRANTOR" if grp == 1 else "GRANTEE"
    return "UNKNOWN"

def make_event_stub(county: str, land_type: str) -> Dict[str,Any]:
    return {
        "event_id": None,
        "event_type": "DEED",
        "county": county,
        "source": {"system": "HAMPDEN_REGISTRY_INDEXPDF", "county": county, "land_type": land_type},
        "document": {"registry_office": "Hampden Registry of Deeds", "land_type": land_type, "doc_type_code_raw": None},
        "recording": {
            "recorded_at_raw": None,
            "recording_date_raw": None,
            "recording_time_raw": None,
            "instrument_number_raw": None,
            "grp_seq_raw": None,
            "book_page_raw": None,
            "ref_book_page_raw": None,
        },
        "consideration": {"amount_raw": None, "amount": None},
        "property_refs": [],
        "parties": [],
        "meta": {"parser": "extract_hampden_indexpdf_recorded_land_deeds_v1_1", "page_indexes": [], "warnings": [], "raw_block": []},
    }

def stable_event_id(county: str, land_type: str, inst: Optional[str], book_page: Optional[str], rec_date: Optional[str]) -> str:
    key = f"MA|registry|indexpdf|{county}|{land_type}|{inst or ''}|{book_page or ''}|{rec_date or ''}"
    h = hashlib.sha1(key.encode("utf-8")).hexdigest()[:24]
    return f"MA|registry|indexpdf|{county}|{h}"

def parse_pdf(pdf_path: str, *, county: str="hampden", land_type: str="RECORDED_LAND",
              progress_every=50,
              flush_every=200,
              start_page: int=0, max_pages: int=0,
              **kwargs,
              ) -> Tuple[List[Dict[str,Any]], List[Dict[str,Any]], Dict[str,Any]]:
    events = []  # only used if on_event is None
    quarantine = []  # only used if on_quarantine is None
    audit={
        "engine": "extract_hampden_indexpdf_recorded_land_deeds_v1_1",
        "inputs": {"pdf": pdf_path, "county": county, "land_type": land_type, "start_page": start_page, "max_pages": max_pages},
        "counts": {"pages_seen": 0, "events_out": 0, "events_quarantined": 0, "non_deed_quarantined": 0},
        "samples": {"quarantine": []},
        "seconds": None,
    }
    t0=time.time()

    current = None  # current event dict
    in_table = False

    def flush_current(reason: Optional[str]=None):
        nonlocal current
        if not current:
            return
        if reason:
            current["meta"]["warnings"].append(reason)

        # minimal validation
        inst = (current.get("recording") or {}).get("instrument_number_raw")
        doc = (current.get("document") or {}).get("doc_type_code_raw")

        # Quarantine if doc_type isn't DEED (safety)
        if doc and doc != "DEED":
            audit["counts"]["non_deed_quarantined"] += 1
            q = {"reason": f"doc_type_not_deed:{doc}", "event": current}
            (on_quarantine(q) if on_quarantine else quarantine.append(q))
            audit["counts"]["events_quarantined"] = audit["counts"].get("events_quarantined", 0) + 1
            if len(audit["samples"]["quarantine"]) < 3:
                audit["samples"]["quarantine"].append({"reason": q["reason"], "inst": inst})
            current = None
            return

        # Required fields gate
        if (not inst) or (not current.get("property_refs")) or (not current.get("parties")):
            q_reason = reason or "missing_required_fields"
            q = {"reason": q_reason, "event": current}
            (on_quarantine(q) if on_quarantine else quarantine.append(q))
            audit["counts"]["events_quarantined"] = audit["counts"].get("events_quarantined", 0) + 1
            if len(audit["samples"]["quarantine"]) < 3:
                audit["samples"]["quarantine"].append({"reason": q_reason, "inst": inst})
            current = None
            return

        # emit valid event
        rec_date = (current.get("recording") or {}).get("recording_date_raw")
        book_page = (current.get("recording") or {}).get("book_page_raw")
        current["event_id"] = stable_event_id(county, land_type, inst, book_page, rec_date)
        (on_event(current) if on_event else events.append(current))
        audit["counts"]["events_out"] = audit["counts"].get("events_out", 0) + 1
        current = None

    with pdfplumber.open(pdf_path) as pdf:
        total_pages = len(pdf.pages)
        end_page = total_pages if max_pages in (0, None) else min(total_pages, start_page + max_pages)

        for pi in range(start_page, end_page):
            if (progress_every and ((pi - start_page) % max(1, int(progress_every)) == 0)) and (pi != start_page):
                elapsed = time.time() - t0
                print(f"[progress] page {pi} events_out={audit['counts'].get('events_out',0)} quarantined={audit['counts'].get('events_quarantined',0)} elapsed_s={elapsed:.2f}")
            page = pdf.pages[pi]
            # orientation normalize (critical for Hampden index PDFs)
            # _pick_best_orientation returns (score, rot, page_obj, words)
            (score, rot, page2, words) = _pick_best_orientation(page)
            page = page2
            # audit counters
            audit['counts']['rotated_pages'] = int(audit['counts'].get('rotated_pages',0) or 0) + (1 if rot else 0)
            audit['counts']['orientation_best_score'] = float(score) if score is not None else audit['counts'].get('orientation_best_score')
            audit["counts"]["pages_seen"] += 1
            page_width = float(page.width)

            # transform chars
            tchars = [transform_char(c, page_width) for c in page.chars]
            lines = build_lines_from_chars(tchars, y_tol=1.0)

            # table start detection: look for the table header keywords
            if not in_table:
                if any(("Recorded" in ln["text"] and "Date/Time" in ln["text"]) or ("Date/Time" in ln["text"] and "Book-Page" in ln["text"]) for ln in lines):
                    in_table = True

            if not in_table:
                continue

            # process lines sequentially
            for ln in lines:
                txt = ln["text"]
                if not txt:
                    continue
                # skip header bands
                if "RECORDED LAND DOCUMENTS" in txt.upper() or "Date/Time" in txt or "Book-Page" in txt:
                    continue

                # dash separator: end of event block
                if RE_DASH.search(txt):
                    flush_current(reason=None)
                    continue

                # town lines
                prop = parse_property_line(txt)
                if prop:
                    if current is None:
                        # create but mark as partial
                        current = make_event_stub(county, land_type)
                        current["meta"]["warnings"].append("town_before_header_row")
                    current["property_refs"].append({
                        "ref_index": len(current["property_refs"]),
                        "town_raw": prop["town"],
                        "address_raw": prop["address_raw"],
                        "unit_hint": None,
                    })
                    current["meta"]["page_indexes"].append(pi)
                    current["meta"]["raw_block"].append(txt)
                    continue

                # party line (strict)
                party = parse_party_line(txt)
                if party:
                    if current is None:
                        current = make_event_stub(county, land_type)
                        current["meta"]["warnings"].append("party_before_header_row")
                    role = group_to_role("DEED", party["party_group"])
                    current["parties"].append({
                        "role": role,
                        "entity_type": pc_to_entity_type(party["pc_flag"]),
                        "name_raw": party["name_raw"],
                        "name_norm": None,
                        "party_group": party["party_group"],
                        "pc_flag": party["pc_flag"],
                        "method": "strict_party_line_v1",
                        "confidence": "A",
                    })
                    current["meta"]["page_indexes"].append(pi)
                    current["meta"]["raw_block"].append(txt)
                    continue

                # likely header row: contains book-page pattern and/or amount + DEED
                if ("DEED" in txt.upper()) or re.search(r"\d{1,3}(?:,\d{3})*(?:\.\d{2})", txt):
                    h = parse_event_header_line(txt)
                    if h.get("doc_type_code_raw") or h.get("instrument_number_raw") or h.get("book_page_raw"):
                        # start new event if we already had one (without dashed separator)
                        if current is not None and (current.get("recording") or {}).get("instrument_number_raw"):
                            flush_current(reason="new_header_row_before_separator")

                        if current is None:
                            current = make_event_stub(county, land_type)

                        current["document"]["doc_type_code_raw"] = h["doc_type_code_raw"]
                        current["recording"]["recorded_at_raw"] = h["recorded_at_raw"]
                        current["recording"]["recording_date_raw"] = h["recording_date_raw"]
                        current["recording"]["recording_time_raw"] = h["recording_time_raw"]
                        current["recording"]["instrument_number_raw"] = h["instrument_number_raw"]
                        current["recording"]["grp_seq_raw"] = h["grp_seq_raw"]
                        current["recording"]["book_page_raw"] = h["book_page_raw"]
                        current["recording"]["ref_book_page_raw"] = h["ref_book_page_raw"]
                        current["consideration"]["amount_raw"] = h["consideration_amount_raw"]
                        current["meta"]["page_indexes"].append(pi)
                        current["meta"]["raw_block"].append(txt)
                        continue

                # otherwise: if we're inside an event, record raw line for debug (bounded)
                if current is not None:
                    if len(current["meta"]["raw_block"]) < 200:
                        current["meta"]["raw_block"].append(txt)

            # end page loop

        # flush at EOF
        flush_current(reason="eof_flush")

    audit["counts"]["events_out"] = int(audit["counts"].get("events_out", 0) or 0)
    audit["counts"]["events_quarantined"] = int(audit["counts"].get("events_quarantined", 0) or 0)
    audit["seconds"] = round(time.time()-t0, 2)
    return events, quarantine, audit

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--pdf", required=True)
    ap.add_argument("--out", required=True)
    ap.add_argument("--audit", required=True)
    ap.add_argument("--quarantine_dir", required=True)
    ap.add_argument("--start_page", type=int, default=0)
    ap.add_argument("--max_pages", type=int, default=0, help="0 = all pages")

    ap.add_argument("--progress_every", type=int, default=50, help="Print progress every N pages (default: 50).")
    ap.add_argument("--flush_every", type=int, default=200, help="Flush output every N events (default: 200).")
    ap.add_argument("--force", action="store_true", help="Allow overwriting existing output/audit/quarantine outputs.")
    args = ap.parse_args()

    os.makedirs(os.path.dirname(args.out), exist_ok=True)
    os.makedirs(os.path.dirname(args.audit), exist_ok=True)
    os.makedirs(args.quarantine_dir, exist_ok=True)


    # Safety: avoid overwriting unless --force
    if (not args.force) and os.path.exists(args.out):
        raise SystemExit(f"[fatal] out already exists (use --force): {args.out}")
    if (not args.force) and os.path.exists(args.audit):
        raise SystemExit(f"[fatal] audit already exists (use --force): {args.audit}")

    q_path = os.path.join(args.quarantine_dir, "quarantine__recorded_land_deeds_v1_1.ndjson")


    # Stream output as we parse so huge PDFs don't look "frozen"
    t0 = time.time()
    events_out = 0
    quar_out = 0
    with open(args.out, "w", encoding="utf-8", newline="\n") as out_f,          open(q_path, "w", encoding="utf-8", newline="\n") as q_f:

        def on_event(e):
            nonlocal events_out
            out_f.write(json.dumps(e, ensure_ascii=False) + "\n")
            events_out += 1
            if (events_out % max(1, int(args.flush_every))) == 0:
                out_f.flush()

        def on_quarantine(q):
            nonlocal quar_out
            q_f.write(json.dumps(q, ensure_ascii=False) + "\n")
            quar_out += 1
            if (quar_out % max(1, int(args.flush_every))) == 0:
                q_f.flush()

    res = parse_pdf(
            args.pdf,
            county="hampden",
            land_type="RECORDED_LAND",
            start_page=args.start_page,
            max_pages=args.max_pages,
            progress_every=args.progress_every,
            on_event=on_event,
            on_quarantine=on_quarantine
        )

    # parse_pdf may return either audit-dict OR (events, quarantine, audit)
    events = []
    quarantine = []
    audit = None
    if isinstance(res, tuple) and len(res) == 3:
        events, quarantine, audit = res
    else:
        audit = res

    if not isinstance(audit, dict):
        raise TypeError(f"parse_pdf() returned unexpected type: {type(audit).__name__}")


    # write audit after parse
    with open(args.audit, "w", encoding="utf-8", newline="\n") as f:
        f.write(json.dumps(audit, ensure_ascii=False, indent=2) + "\n")

    print(json.dumps({
        "engine": audit.get("engine"),
        "inputs": audit.get("inputs"),
        "counts": audit.get("counts"),
        "outputs": {"out": args.out, "quarantine": q_path, "audit": args.audit},
        "sha256_out": sha256_file(args.out)
    }, ensure_ascii=False))
if __name__ == "__main__":
    main()







