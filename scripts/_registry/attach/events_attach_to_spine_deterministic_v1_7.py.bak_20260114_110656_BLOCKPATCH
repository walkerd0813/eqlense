# reverse: preferred "long" for readability variants (optional)
SUFFIX_LONG = {}
for k,v in SUFFIX_CANON.items():
    # pick a representative long form for each canon token
    if len(k) > 3 and v not in SUFFIX_LONG:
        SUFFIX_LONG[v] = k

RE_MULTI_RANGE = re.compile(r"^(?P<a>\d+)\s*-\s*(?P<b>\d+)\s*(?P<rest>.+)$", re.IGNORECASE)

# unit extraction (single fragment)
RE_UNIT_FULL = re.compile(
    r"\b(?P<des>(UNIT|APT|APARTMENT|#|PH|PENTHOUSE|BSMT|BASEMENT|FL|FLOOR|RM|ROOM|STE|SUITE))\b"
    r"(?:\s*(?P<val>[A-Z0-9][A-Z0-9\-]*))?\b",
    re.IGNORECASE
)

RE_HASH_UNIT = re.compile(r"(?:^|\s)#\s*(?P<val>[A-Z0-9][A-Z0-9\-]*)\b", re.IGNORECASE)
UNIT_DESIGNATOR_NORM = {
    "APARTMENT":"APT",
    "#":"UNIT",
    "PENTHOUSE":"PH",
    "BASEMENT":"BSMT",
    "FLOOR":"FL",
    "ROOM":"RM",
    "SUITE":"STE",
}

# Boston neighborhood -> BOSTON (safe)
BOSTON_NEIGHBORHOODS = {
  "DORCHESTER","BRIGHTON","JAMAICA PLAIN","SOUTH BOSTON","EAST BOSTON","CHARLESTOWN",
  "ROSLINDALE","WEST ROXBURY","HYDE PARK","ROXBURY","ALLSTON","MATTAPAN","CHESTNUT HILL",
  "SOUTH BOSTON WATERFRONT","DOWNTOWN","NORTH END","BACK BAY","BEACON HILL","FENWAY","MISSION HILL",
}
BOSTON_NEIGHBOR_MISSPELL = {
  "DORCHESTERE":"DORCHESTER",
  "WESY ROXBURY":"WEST ROXBURY",
  "WEST ROXBURY Q":"WEST ROXBURY",
}

def sha256_text(s: str) -> str:
    h = hashlib.sha256()
    h.update((s or "").encode("utf-8", errors="ignore"))
    return h.hexdigest()

def norm_space_upper(x) -> str:
    s = re.sub(r"\s+"," ", str(x or "").strip().upper())
    s = s.replace(".", " ")
    s = re.sub(r"\s+"," ", s).strip()
    return s or ""

def norm_town(t):
    s = norm_space_upper(t)
    return s or None

def town_canonical_from_event(pr: dict):
    for k in ("town_code","town_norm","town_raw"):
        tn = norm_town(pr.get(k))
        if not tn: continue
        if tn in BOSTON_NEIGHBOR_MISSPELL: tn = BOSTON_NEIGHBOR_MISSPELL[tn]
        if tn in BOSTON_NEIGHBORHOODS: return "BOSTON"
        return tn
    pd = norm_town(pr.get("prop_desc_raw"))
    if pd in BOSTON_NEIGHBOR_MISSPELL: pd = BOSTON_NEIGHBOR_MISSPELL[pd]
    if pd in BOSTON_NEIGHBORHOODS: return "BOSTON"
    return None

def norm_addr(a):
    if a is None: return None
    s = norm_space_upper(a)
    s = re.sub(r"\s+Y$", "", s).strip()
    parts = s.split(" ")
    if parts and parts[0] in NUMWORD:
        parts[0] = NUMWORD[parts[0]]
    return " ".join(parts).strip() or None

def pick_spine_addr_str(r: dict):
    for k in ("address_norm","address","address_raw","address_full","site_address","full_address","address1"):
        v = r.get(k)
        if isinstance(v, str) and v.strip():
            return v
    return None

def pick_spine_unit_fields(r: dict):
    # deterministic: only use explicit fields if present
    for k in ("unit","unit_num","unit_number","apt","apt_num","apartment","suite","suite_num","condo_unit","unitid"):
        v = r.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()
        if isinstance(v, (int,float)) and str(v).strip():
            return str(int(v))
    return None

def extract_unit(addr_norm: str):
    """
    Deterministic unit extraction.
    Returns: (core_addr_norm, unit_designator_norm|None, unit_value_norm|None, had_unit_bool)
    """
    if not addr_norm:
        return (addr_norm, None, None, False)

    # hash style units: "#H", "# 11-15", "#DH-B"
    mh = RE_HASH_UNIT.search(addr_norm)
    if mh:
        val = (mh.group("val") or "").upper().strip() or None
        core = (addr_norm[:mh.start()] + " " + addr_norm[mh.end():]).strip()
        core = re.sub(r"\s+", " ", core).strip()
        return (core, "UNIT", val, True)

    m = RE_UNIT_FULL.search(addr_norm)
    if not m:
        return (addr_norm, None, None, False)

    des = (m.group("des") or "").upper()
    val = (m.group("val") or "").upper().strip() or None
    des = UNIT_DESIGNATOR_NORM.get(des, des)

    core = (addr_norm[:m.start()] + " " + addr_norm[m.end():]).strip()
    core = re.sub(r"\s+", " ", core).strip()
    return (core, des, val, True)

def normalize_unit(des: str, val: str):
    des = (des or "").strip().upper()
    val = (val or "").strip().upper() if val else None
    if not des and not val:
        return None
    if des and not val:
        return des
    if not des and val:
        return val
    return f"{des} {val}".strip()

def strip_lot(addr_norm):
    if not addr_norm: return addr_norm
    s = re.sub(r"\bLOT\b[\s#]*([0-9]+|[A-Z])?\b", "", addr_norm, flags=re.IGNORECASE).strip()
    s = re.sub(r"\s+"," ", s).strip()
    return s

def cleanup_addr_tail(addr_norm):
    if not addr_norm: return addr_norm
    s = re.sub(r"\s+"," ", addr_norm).strip()
    s = re.sub(r"\s+[A-Z]$", "", s).strip()  # trailing single-letter junk

    # strip trailing Boston neighborhood tokens if appended
    toks = s.split()
    if len(toks) >= 2:
        last2 = " ".join(toks[-2:])
        if last2 in BOSTON_NEIGHBORHOODS:
            s = " ".join(toks[:-2]).strip()
    toks = s.split()
    if toks and toks[-1] in BOSTON_NEIGHBORHOODS:
        s = " ".join(toks[:-1]).strip()

    # safer MD tail strip only if it looks like a trailing artifact
    s = re.sub(r"\s+\bMD\s+\d+\b.*$", "", s).strip()
    s = re.sub(r"\s+"," ", s).strip()
    return s

def expand_range(addr_norm):
    m = RE_MULTI_RANGE.match(addr_norm or "")
    if not m: return []
    a = int(m.group("a")); b = int(m.group("b"))
    rest = m.group("rest").strip()
    lo,hi = (a,b) if a<=b else (b,a)
    if hi-lo <= 10:
        return [f"{n} {rest}" for n in range(lo, hi+1)]
    return [f"{lo} {rest}", f"{hi} {rest}"]

def mt_mount_variants(addr_norm):
    if not addr_norm: return []
    toks = addr_norm.split()
    out=[]
    if "MT" in toks:
        out.append(" ".join(["MOUNT" if t=="MT" else t for t in toks]))
    if "MOUNT" in toks:
        out.append(" ".join(["MT" if t=="MOUNT" else t for t in toks]))
    return list(dict.fromkeys([v for v in out if v]))

def st_saint_streetname_variants(addr_norm):
    if not addr_norm: return []
    toks = addr_norm.split()
    if len(toks) < 3: return []
    if not toks[0].isdigit(): return []
    if toks[1] == "ST":
        return [" ".join([toks[0],"SAINT"] + toks[2:])]
    if toks[1] == "SAINT":
        return [" ".join([toks[0],"ST"] + toks[2:])]
    return []

def suffix_variants(addr_norm):
    toks = (addr_norm or "").split()
    if not toks: return []
    last = toks[-1].upper()
    if last not in SUFFIX_CANON:
        return []

    canon = SUFFIX_CANON[last]
    out=set()
    if canon != last:
        out.add(" ".join(toks[:-1] + [canon]))
    # optional long-form variant
    longv = SUFFIX_LONG.get(canon)
    if longv and longv != last:
        out.add(" ".join(toks[:-1] + [longv]))
    return list(out)

# deterministic patterns for route/highway streetnames:
#  - "123 RT 9" -> "123 RTE 9" and "123 ROUTE 9"
#  - "123 I 93" -> "123 I-93" variant (and back)
RE_ROUTE = re.compile(r"^(?P<num>\d+)\s+(?P<tag>RT|RTE|ROUTE)\s+(?P<rnum>\d+)\b", re.IGNORECASE)
RE_I = re.compile(r"^(?P<num>\d+)\s+I[\s\-]?(?P<inum>\d+)\b", re.IGNORECASE)
RE_US = re.compile(r"^(?P<num>\d+)\s+US[\s\-]?(?P<usnum>\d+)\b", re.IGNORECASE)
RE_STATE = re.compile(r"^(?P<num>\d+)\s+(MA|SR|STATE\s+ROUTE)[\s\-]?(?P<snum>\d+)\b", re.IGNORECASE)

def highway_variants(addr_norm):
    s = addr_norm or ""
    out=set()

    m = RE_ROUTE.match(s)
    if m:
        n = m.group("num"); rnum = m.group("rnum")
        out.add(f"{n} RTE {rnum}")
        out.add(f"{n} ROUTE {rnum}")

    m = RE_I.match(s)
    if m:
        n = m.group("num"); inum = m.group("inum")
        out.add(f"{n} I-{inum}")
        out.add(f"{n} I {inum}")

    m = RE_US.match(s)
    if m:
        n = m.group("num"); usnum = m.group("usnum")
        out.add(f"{n} US-{usnum}")
        out.add(f"{n} US {usnum}")

    m = RE_STATE.match(s)
    if m:
        n = m.group("num"); snum = m.group("snum")
        out.add(f"{n} MA-{snum}")
        out.add(f"{n} STATE ROUTE {snum}")
        out.add(f"{n} SR {snum}")

    out.discard(s)
    return list(out)

def addr_variants(addr_norm):
    out=[]
    seen=set()
    def add(v, tag):
        if not v: return
        if v in seen: return
        seen.add(v); out.append((v, tag))

    if not addr_norm:
        return out

    a0 = cleanup_addr_tail(addr_norm)
    add(a0, "direct")

    core, des, val, had_unit = extract_unit(a0)
    core = strip_lot(re.sub(r"\s+"," ", (core or "").strip()).strip())
    add(core, "core_unit_stripped" if had_unit else "core")

    for v in expand_range(core):
        add(v, "range_expand")

    for v in suffix_variants(core):
        add(v, "suffix_canon")

    for v in highway_variants(core):
        add(v, "highway_variant")

    for v in mt_mount_variants(core):
        add(v, "mt_mount")
    for v in st_saint_streetname_variants(core):
        add(v, "st_saint")

    # controlled combos
    for v in suffix_variants(core):
        for vv in mt_mount_variants(v):
            add(vv, "suffix_canon+mt_mount")
        for vv in st_saint_streetname_variants(v):
            add(vv, "suffix_canon+st_saint")

    return out

def load_spine_pointer(spine_current_json):
    raw = open(spine_current_json,"r",encoding="utf-8").read().strip()
    cand = raw.strip().strip('"')
    if cand.lower().endswith(".ndjson") and os.path.exists(cand):
        return cand
    obj = json.loads(raw)
    found=[]
    def walk(x):
        if isinstance(x, dict):
            for v in x.values(): walk(v)
        elif isinstance(x, list):
            for v in x: walk(v)
        elif isinstance(x, str):
            s = x.strip().strip('"')
            if s.lower().endswith(".ndjson"):
                found.append(s)
    walk(obj)
    for p in found:
        if os.path.exists(p):
            return p
    raise RuntimeError("Could not resolve spine ndjson path from CURRENT pointer JSON.")

def build_spine_indices(spine_ndjson, towns_set):
    base_index={}
    unit_index={}
    collisions_base=0
    collisions_unit=0
    rows_seen=0
    rows_indexed=0

    def put(idx, key, pid):
        nonlocal collisions_base, collisions_unit
        if key in idx and idx[key] != pid:
            idx[key] = "__COLLISION__"
            if idx is base_index: collisions_base += 1
            else: collisions_unit += 1
        else:
            idx[key] = pid

    with open(spine_ndjson,"r",encoding="utf-8") as f:
        for line in f:
            line=line.strip()
            if not line: continue
            rows_seen += 1
            try:
                r=json.loads(line)
            except Exception:
                continue

            town = norm_town(r.get("town_norm") or r.get("town") or r.get("municipality") or r.get("city"))
            if not town or town not in towns_set:
                continue

            addr_raw = pick_spine_addr_str(r)
            if not addr_raw:
                continue
            addr = norm_addr(addr_raw)
            pid = r.get("property_id")
            if not addr or not pid:
                continue

            rows_indexed += 1

            # base from string
            base_addr, des, val, _had = extract_unit(addr)
            base_addr = strip_lot(cleanup_addr_tail(base_addr or ""))

            # unit from: (a) string, (b) explicit unit fields
            unit_from_str = normalize_unit(des, val)
            unit_from_field = norm_space_upper(pick_spine_unit_fields(r))
            unit_from_field = unit_from_field or None

            # BASE
            for av,_tag in addr_variants(base_addr):
                put(base_index, f"{town}|{av}", pid)

            # UNIT
            for unit_key in [unit_from_str, unit_from_field]:
                if not unit_key:
                    continue
                for av,_tag in addr_variants(base_addr):
                    put(unit_index, f"{town}|{av}|{unit_key}", pid)

    stats = {
        "spine_rows_seen": rows_seen,
        "spine_rows_indexed": rows_indexed,
        "base_keys": len(base_index),
        "unit_keys": len(unit_index),
        "collision_events_base": collisions_base,
        "collision_events_unit": collisions_unit
    }
    return base_index, unit_index, stats

def event_addr_candidates(pr: dict):
    """
    Deterministic reconstruction for consultant feeds where fields contain multiple addresses.
    Returns ordered list of normalized candidate address strings.
    """
    out=[]
    seen=set()

    def add(x):
        x = norm_addr(x)
        if not x: return
        if x in seen: return
        seen.add(x); out.append(x)

    # town can be mashed: "SPRINGFIELD, 0 NEW SALEM RD"
    town_raw = pr.get("town_raw") or pr.get("town_norm") or pr.get("town_code") or ""
    if isinstance(town_raw, str) and "," in town_raw:
        parts = [p.strip() for p in town_raw.split(",") if p.strip()]
        # first is town-ish, remainder might be address
        for p in parts[1:]:
            add(p)

    # base address field (may contain commas)
    base = pr.get("address_norm") or pr.get("address_raw") or pr.get("address") or ""
    if isinstance(base, str) and "," in base:
        for seg in base.split(","):
            if seg.strip():
                add(seg.strip())
    add(base)

    # street_no + street_name (may be comma lists)
    sn = pr.get("street_no")
    st = pr.get("street_name")
    if sn and st:
        sn_list = [x.strip() for x in str(sn).split(",") if x.strip()]
        st_list = [x.strip() for x in str(st).split(",") if x.strip()]

        # zip pairing if aligned, else controlled combos (cap)
        if len(sn_list) == len(st_list) and len(sn_list) <= 10:
            for a,b in zip(sn_list, st_list):
                add(f"{a} {b}")
        else:
            combos=0
            for a in sn_list[:5]:
                for b in st_list[:5]:
                    add(f"{a} {b}")
                    combos += 1
                    if combos >= 20: break

    return out
def attach_one(town_norm, addr_norm, base_index, unit_index):
    if not town_norm or not addr_norm:
        return ("MISSING_TOWN_OR_ADDRESS", None, None, None)

    base_addr, des, val, _had = extract_unit(addr_norm)
    base_addr = strip_lot(cleanup_addr_tail(base_addr or ""))
    unit_key = normalize_unit(des, val)

    # unit-first
    if unit_key:
        for av,tag in addr_variants(base_addr):
            ku = f"{town_norm}|{av}|{unit_key}"
            if ku in unit_index:
                if unit_index[ku] == "__COLLISION__":
                    return ("UNKNOWN", None, "collision_unit", ku)
                return ("ATTACHED_A", unit_index[ku], f"unit|{tag}", ku)

    # base fallback
    for av,tag in addr_variants(base_addr):
        k = f"{town_norm}|{av}"
        if k in base_index:
            if base_index[k] == "__COLLISION__":
                return ("UNKNOWN", None, "collision_base", k)
            return ("ATTACHED_A", base_index[k], f"base|{tag}", k)

    if unit_key:
        return ("UNKNOWN", None, "no_match_unit_then_base", f"{town_norm}|{base_addr}|{unit_key}")
    return ("UNKNOWN", None, "no_match_base", f"{town_norm}|{base_addr}")

