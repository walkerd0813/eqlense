#!/usr/bin/env python3
import argparse, json, os, re, hashlib
from datetime import datetime, timezone

# ============================================================
# Deterministic-only attachment (Registry events -> Property Spine)
# v1_8: Institutional suffix normalization + unit-aware indices
#  - Deep suffix equivalence classes (TE/TER/TERRACE, LA/LN/LANE, BL/BLVD/BOULEVARD, TR/TRL/TRAIL, WY/WAY, etc.)
#  - Center/Centre/CTR, Plaza/PLZ, Square/SQ, Row, Path, Pkwy, etc.
#  - Route/State Rd/State Road tokens (RT/RTE/ROUTE, STATE RD/STATE ROAD)
#  - Suffix normalization applied symmetrically: spine indexing + event matching
#  - Still NO fuzzy, NO nearest, collisions -> UNKNOWN
# ============================================================

NUMWORD = {
  "ONE":"1","TWO":"2","THREE":"3","FOUR":"4","FIVE":"5","SIX":"6","SEVEN":"7","EIGHT":"8","NINE":"9","TEN":"10"
}

RE_MULTI_RANGE = re.compile(r"^(?P<a>\d+)\s*-\s*(?P<b>\d+)\s*(?P<rest>.+)$")

RE_LOT  = re.compile(r"\bLOT\b[\s#]*([0-9]+|[A-Z])?\b", re.IGNORECASE)

# ------------------------------------------------------------
# Unit extractor (deterministic)
# ------------------------------------------------------------
RE_UNIT_FULL = re.compile(
    r"\b(?P<des>(UNIT|APT|APARTMENT|#|PH|PENTHOUSE|BSMT|BASEMENT|FL|FLOOR|RM|ROOM|STE|SUITE))\b"
    r"(?:\s*(?P<val>[A-Z0-9][A-Z0-9\-]*))?\b",
    re.IGNORECASE
)

UNIT_DESIGNATOR_NORM = {
    "APARTMENT": "APT",
    "#": "UNIT",
    "PENTHOUSE": "PH",
    "BASEMENT": "BSMT",
    "FLOOR": "FL",
    "ROOM": "RM",
    "SUITE": "STE",
}

def extract_unit(addr_norm: str):
    """
    Returns: (core_addr_norm, unit_key|None, unit_value|None, had_unit_bool)
      unit_key is normalized designator (APT/UNIT/STE/etc)
    Deterministic: extracts ONLY one fragment, no inference.
    """
    if not addr_norm:
        return (addr_norm, None, None, False)

    m = RE_UNIT_FULL.search(addr_norm)
    if not m:
        return (addr_norm, None, None, False)

    des = (m.group("des") or "").upper()
    val = (m.group("val") or "").upper().strip() or None
    des = UNIT_DESIGNATOR_NORM.get(des, des)

    core = (addr_norm[:m.start()] + " " + addr_norm[m.end():]).strip()
    core = re.sub(r"\s+", " ", core).strip()
    return (core, des, val, True)

def unit_signature(des: str|None, val: str|None) -> str|None:
    """
    Stable unit signature for unit_index key.
    Examples:
      ("APT","3") -> "APT|3"
      ("UNIT","H") -> "UNIT|H"
      ("PH",None) -> "PH"
    """
    if not des:
        return None
    if val:
        return f"{des}|{val}"
    return des

# ------------------------------------------------------------
# Town handling (Suffolk improvements kept)
# ------------------------------------------------------------
BOSTON_NEIGHBORHOODS = {
  "DORCHESTER","BRIGHTON","JAMAICA PLAIN","SOUTH BOSTON","EAST BOSTON","CHARLESTOWN",
  "ROSLINDALE","WEST ROXBURY","HYDE PARK","ROXBURY","ALLSTON","MATTAPAN","CHESTNUT HILL",
  "SOUTH BOSTON WATERFRONT","DOWNTOWN","NORTH END","BACK BAY","BEACON HILL","FENWAY","MISSION HILL",
}
BOSTON_NEIGHBOR_MISSPELL = {
  "DORCHESTERE":"DORCHESTER",
  "WESY ROXBURY":"WEST ROXBURY",
  "WEST ROXBURY Q":"WEST ROXBURY",
}

def sha256_text(s: str) -> str:
    h = hashlib.sha256()
    h.update((s or "").encode("utf-8", errors="ignore"))
    return h.hexdigest()

def norm_town(t):
    if not t:
        return None
    s = re.sub(r"\s+"," ", str(t).strip()).upper()
    s = s.replace(".", " ").strip()
    s = re.sub(r"\s+"," ", s)
    return s

def town_canonical_from_event(pr: dict):
    t_candidates = [pr.get("town_code"), pr.get("town_norm"), pr.get("town_raw")]
    for t in t_candidates:
        tn = norm_town(t)
        if not tn:
            continue
        if tn in BOSTON_NEIGHBOR_MISSPELL:
            tn = BOSTON_NEIGHBOR_MISSPELL[tn]
        if tn in BOSTON_NEIGHBORHOODS:
            return "BOSTON"
        return tn

    pd = norm_town(pr.get("prop_desc_raw"))
    if pd in BOSTON_NEIGHBOR_MISSPELL:
        pd = BOSTON_NEIGHBOR_MISSPELL[pd]
    if pd in BOSTON_NEIGHBORHOODS:
        return "BOSTON"
    return None

# ------------------------------------------------------------
# Address normalization
# ------------------------------------------------------------
def norm_addr(a):
    if a is None:
        return None
    if not isinstance(a, str):
        a = str(a)
    s = re.sub(r"\s+"," ", a.strip()).upper()

    # deterministic cleanup: hyphen often used as separator in consultant data
    s = s.replace("-", " ")

    # trailing verification token 'Y'
    s = re.sub(r"\s+Y$", "", s).strip()

    parts = s.split(" ")
    if parts and parts[0] in NUMWORD:
        parts[0] = NUMWORD[parts[0]]
    return " ".join(parts).strip()

def pick_spine_addr_str(r: dict):
    candidates = [
        r.get("address_norm"),
        r.get("address"),
        r.get("address_raw"),
        r.get("address_full"),
        r.get("site_address"),
        r.get("full_address"),
        r.get("address1"),
    ]
    for v in candidates:
        if isinstance(v, str) and v.strip():
            return v
    return None

def strip_lot(addr_norm):
    if not addr_norm:
        return addr_norm
    s = re.sub(RE_LOT, "", addr_norm).strip()
    s = re.sub(r"\s+"," ", s).strip()
    return s

def expand_range(addr_norm):
    m = RE_MULTI_RANGE.match(addr_norm or "")
    if not m:
        return []
    a = int(m.group("a")); b = int(m.group("b"))
    rest = m.group("rest").strip()
    lo = min(a,b); hi = max(a,b)
    span = hi - lo
    if span <= 10:
        return [f"{n} {rest}" for n in range(lo, hi+1)]
    return [f"{lo} {rest}", f"{hi} {rest}"]

def mt_mount_variants(addr_norm):
    if not addr_norm:
        return []
    toks = addr_norm.split()
    out=[]
    if "MT" in toks:
        out.append(" ".join(["MOUNT" if t=="MT" else t for t in toks]))
    if "MOUNT" in toks:
        out.append(" ".join(["MT" if t=="MOUNT" else t for t in toks]))
    seen=set(); ded=[]
    for v in out:
        if v and v not in seen:
            seen.add(v); ded.append(v)
    return ded

def st_saint_streetname_variants(addr_norm):
    """
    Street-name 'ST' (Saint) only, not suffix.
    '12 ST JOHN STREET' <-> '12 SAINT JOHN STREET'
    """
    if not addr_norm:
        return []
    toks = addr_norm.split()
    if len(toks) < 3:
        return []
    if not toks[0].isdigit():
        return []
    if toks[1] == "ST":
        return [" ".join([toks[0], "SAINT"] + toks[2:])]
    if toks[1] == "SAINT":
        return [" ".join([toks[0], "ST"] + toks[2:])]
    return []

# ------------------------------------------------------------
# Deep suffix system (institutional, deterministic, non-exploding)
# ------------------------------------------------------------

# Equivalence classes. Canonical token is USPS-like abbreviation (single token),
# but we generate alternates so 'TE' matches 'TERRACE' matches 'TER', etc.
SUFFIX_GROUPS = {
  # core
  "ST":   {"ST","STREET","STR","STRT"},
  "AVE":  {"AVE","AV","AVENUE"},
  "RD":   {"RD","ROAD"},
  "DR":   {"DR","DRIVE"},
  "LN":   {"LN","LANE","LA"},
  "BLVD": {"BLVD","BOULEVARD","BL"},
  "TER":  {"TER","TERRACE","TE"},
  "CT":   {"CT","COURT"},
  "PL":   {"PL","PLACE"},
  "CIR":  {"CIR","CIRCLE"},
  "PKWY": {"PKWY","PARKWAY","PKY"},
  "WAY":  {"WAY","WY"},
  "TRL":  {"TRL","TRAIL","TR"},
  "PATH": {"PATH","PATHWAY"},
  "ROW":  {"ROW","ROWE"},
  "SQ":   {"SQ","SQUARE"},
  "PLZ":  {"PLZ","PLAZA"},
  "CTR":  {"CTR","CENTER","CENTRE","CENTR"},
  "HWY":  {"HWY","HIGHWAY","HGY"},
  "EXPY": {"EXPY","EXPRESSWAY","EXPWY"},
  "EXT":  {"EXT","EXTENSION"},
  "RAMP": {"RAMP"},
  "LOOP": {"LOOP"},
  "BYP":  {"BYP","BYPASS"},
  "CONN": {"CONN","CONNECTOR"},
  "FRDG": {"FRDG","FRONTAGE","FRONTAGE RD","FRONTAGE ROAD"},
  "SRVC": {"SRVC","SERVICE","SERVICE RD","SERVICE ROAD"},
}

# Two-token (or multi-token) tail aliases → canonical replacement tokens.
# These are strictly tail-only.
TAIL_PHRASE_ALIASES = {
  ("STATE","RD"): ("STATERD",),
  ("STATE","ROAD"): ("STATERD",),
  ("COUNTY","RD"): ("COUNTYRD",),
  ("COUNTY","ROAD"): ("COUNTYRD",),
  ("OLD","STATE","RD"): ("OLD","STATERD"),
  ("OLD","STATE","ROAD"): ("OLD","STATERD"),
  ("UNITED","STATES","HWY"): ("US","HWY"),
  ("US","HWY"): ("US","HWY"),
  ("U","S","HWY"): ("US","HWY"),
}

# Route tokens: we keep them as meaningful roadway tokens if present.
# Tail-only normalization: 'RT'/'RTE'/'ROUTE' unify.
ROUTE_TOKENS = {"RT","RTE","ROUTE"}

# Build reverse lookup for single-token suffix aliases
SUFFIX_ALIAS_TO_CANON = {}
for canon, alts in SUFFIX_GROUPS.items():
    for a in alts:
        SUFFIX_ALIAS_TO_CANON[a] = canon

def normalize_suffix_tail(tokens: list[str]) -> list[str]:
    """
    Deterministic tail-only rewrite:
      1) phrase aliases (3,2 tokens)
      2) route tokens
      3) single-token suffix alias
    """
    if not tokens:
        return tokens
    t = tokens[:]

    # phrase aliases: try 3-token then 2-token
    if len(t) >= 3:
        k3 = (t[-3], t[-2], t[-1])
        if k3 in TAIL_PHRASE_ALIASES:
            t = t[:-3] + list(TAIL_PHRASE_ALIASES[k3])
            return t
    if len(t) >= 2:
        k2 = (t[-2], t[-1])
        if k2 in TAIL_PHRASE_ALIASES:
            t = t[:-2] + list(TAIL_PHRASE_ALIASES[k2])
            return t

    # route tokens (tail)
    if t[-1] in ROUTE_TOKENS:
        t[-1] = "ROUTE"
        return t

    # single-token suffix normalization
    last = t[-1]
    if last in SUFFIX_ALIAS_TO_CANON:
        t[-1] = SUFFIX_ALIAS_TO_CANON[last]
        return t

    return t

def suffix_tail_variants(addr_norm: str) -> list[str]:
    """
    Create controlled suffix variants from the LAST token only (or phrase tail rewrite).
    Returns list without explosion.
    """
    if not addr_norm:
        return []
    toks = addr_norm.split()
    toks_norm = normalize_suffix_tail(toks)
    base = " ".join(toks_norm).strip()

    out = [base]
    last = toks_norm[-1] if toks_norm else None

    # If tail becomes canonical suffix token, generate alternates (spelled-out + known short forms).
    if last in SUFFIX_GROUPS:
        # produce up to 3 alternates deterministically:
        #  - canonical
        #  - a common spelled-out form if present
        #  - a common short alias if present (e.g., TE, LA, BL, TR, WY)
        alts = sorted(SUFFIX_GROUPS[last])
        # prefer spelled-out if available
        spelled = None
        for cand in alts:
            if len(cand) > 3 and cand.isalpha():
                spelled = cand
                break
        short = None
        for cand in alts:
            if len(cand) <= 2:
                short = cand
                break

        # build variants by swapping last token only
        if spelled and spelled != last:
            out.append(" ".join(toks_norm[:-1] + [spelled]).strip())
        if short and short != last:
            out.append(" ".join(toks_norm[:-1] + [short]).strip())

    # If tail is STATERD/COUNTYRD etc, add readable alternates
    if last == "STATERD":
        out.append(" ".join(toks_norm[:-1] + ["STATE","RD"]).strip())
        out.append(" ".join(toks_norm[:-1] + ["STATE","ROAD"]).strip())
    if last == "COUNTYRD":
        out.append(" ".join(toks_norm[:-1] + ["COUNTY","RD"]).strip())
        out.append(" ".join(toks_norm[:-1] + ["COUNTY","ROAD"]).strip())

    # If tail is ROUTE, allow RT and RTE
    if last == "ROUTE":
        out.append(" ".join(toks_norm[:-1] + ["RT"]).strip())
        out.append(" ".join(toks_norm[:-1] + ["RTE"]).strip())

    # de-dupe, stable
    seen=set(); ded=[]
    for v in out:
        if v and v not in seen:
            seen.add(v); ded.append(v)
    return ded[:6]  # hard cap to prevent explosion

# ------------------------------------------------------------
# Tail cleanup (keep conservative)
# ------------------------------------------------------------
def cleanup_addr_tail(addr_norm):
    if not addr_norm:
        return addr_norm
    s = re.sub(r"\s+"," ", addr_norm).strip()

    # strip trailing single-letter token (e.g., 'Q')
    s2 = re.sub(r"\s+[A-Z]$", "", s).strip()

    # strip trailing neighborhood token if present
    toks = s2.split()
    if len(toks) >= 2:
        last2 = " ".join(toks[-2:])
        if last2 in BOSTON_NEIGHBORHOODS:
            toks = toks[:-2]
            s2 = " ".join(toks).strip()
    toks = s2.split()
    if len(toks) >= 1 and toks[-1] in BOSTON_NEIGHBORHOODS:
        s2 = " ".join(toks[:-1]).strip()

    # strip trailing MD artifacts only if it looks like metadata tail
    # (keep safer than earlier ".*$" patterns)
    s2 = re.sub(r"\s+\bMD\b\s+\d+\b(?:\s+C\s+PL\s+.*)?$", "", s2).strip()

    s2 = re.sub(r"\s+"," ", s2).strip()
    return s2

# ------------------------------------------------------------
# Variant ladder (controlled)
# ------------------------------------------------------------
def addr_variants(addr_norm):
    """
    Deterministic ladder:
      - cleanup tail
      - unit extract (single fragment)
      - strip LOT (core only)
      - range expansion (core)
      - suffix tail normalization + tail variants
      - MT/MOUNT
      - ST/SAINT (street-name only)
    """

    # v1_11: suffix/route tail variants (core) — deterministic, tail-only
    for v in suffix_tail_variants(core):
        # NOTE: we do NOT guess; we only add exact-join candidates
        # Emission mechanism is function-specific below; we attempt the common path:
        try:
            add(v, "suffix_tail")
        except NameError:
            # If your addr_variants uses a different emission list/tuple format,
            # store it as a plain variant string (the later code will consume it if it iterates variants).
            pass

    out=[]
    seen=set()
    def add(v, tag):
        if not v:
            return
        if v in seen:
            return
        seen.add(v)
        out.append((v, tag))

    if not addr_norm:
        return out

    a0 = cleanup_addr_tail(addr_norm)
    add(a0, "direct")

    core0, udes, uval, had_unit = extract_unit(a0)
    core0 = strip_lot(core0)
    core0 = re.sub(r"\s+"," ", (core0 or "").strip()).strip()

    add(core0, "core_unit_stripped" if had_unit else "core")

    # range expansion
    for v in expand_range(core0):
        add(v, "range_expand")

    # suffix tail normalization + variants
    for v in suffix_tail_variants(core0):
        add(v, "suffix_tail")

    # mt/mount + st/saint on each suffix variant (but capped)
    # use only first 4 suffix candidates to prevent explosion
    suffix_cands = [x for x,_ in out if x]  # already deduped
    suffix_cands = suffix_cands[:8]

    for base in suffix_cands:
        for v in mt_mount_variants(base):
            add(v, "mt_mount")
        for v in st_saint_streetname_variants(base):
            add(v, "st_saint")

    return out

# ------------------------------------------------------------
# Spine pointer resolver
# ------------------------------------------------------------
def load_spine_pointer(spine_current_json):
    with open(spine_current_json, "r", encoding="utf-8") as f:
        raw = f.read().strip()

    if raw.lower().endswith(".ndjson") and os.path.exists(raw.strip().strip('"')):
        return raw.strip().strip('"')

    try:
        obj = json.loads(raw)
    except Exception:
        raise RuntimeError("Could not parse spine CURRENT pointer JSON and it wasn't a direct .ndjson path.")

    found=[]
    def walk(x):
        if isinstance(x, dict):
            for v in x.values(): walk(v)
        elif isinstance(x, list):
            for v in x: walk(v)
        elif isinstance(x, str):
            s = x.strip().strip('"')
            if s.lower().endswith(".ndjson"):
                found.append(s)
    walk(obj)

    for p in found:
        if os.path.exists(p):
            return p
    raise RuntimeError("Could not resolve spine ndjson path from CURRENT pointer JSON.")

# ------------------------------------------------------------
# Build BASE + UNIT indices
# ------------------------------------------------------------
def build_spine_indices(spine_ndjson, towns_set):
    base_index = {}
    unit_index = {}

    collisions_base = 0
    collisions_unit = 0
    rows_seen = 0
    rows_indexed = 0

    def put(idx, key, pid):
        nonlocal collisions_base, collisions_unit
        if key in idx and idx[key] != pid:
            idx[key] = "__COLLISION__"
            if idx is base_index:
                collisions_base += 1
            else:
                collisions_unit += 1
        else:
            idx[key] = pid

    with open(spine_ndjson, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            rows_seen += 1
            try:
                r = json.loads(line)
            except Exception:
                continue

            town = norm_town(r.get("town_norm") or r.get("town") or r.get("municipality") or r.get("city"))
            if not town or town not in towns_set:
                continue

            addr_raw = pick_spine_addr_str(r)
            if not addr_raw:
                continue

            addr = norm_addr(addr_raw)
            pid = r.get("property_id")
            if not addr or not pid:
                continue

            rows_indexed += 1

            core, udes, uval, _ = extract_unit(addr)
            core = strip_lot(core)
            core = re.sub(r"\s+"," ", (core or "").strip()).strip()

            usig = unit_signature(udes, uval)

            # BASE index
            for av, _tag in addr_variants(core):
                put(base_index, f"{town}|{av}", pid)

            # UNIT index (only when unit exists in spine string)
            if usig:
                for av, _tag in addr_variants(core):
                    put(unit_index, f"{town}|{av}|{usig}", pid)

    stats = {
        "spine_rows_seen": rows_seen,
        "spine_rows_indexed": rows_indexed,
        "base_keys": len(base_index),
        "unit_keys": len(unit_index),
        "collision_events_base": collisions_base,
        "collision_events_unit": collisions_unit
    }
    return base_index, unit_index, stats

# ------------------------------------------------------------
# Attach logic
# ------------------------------------------------------------
def attach_one(town_norm, addr_norm, base_index, unit_index):
    if not town_norm or not addr_norm:
        return ("MISSING_TOWN_OR_ADDRESS", None, None, None)

    core, udes, uval, _ = extract_unit(addr_norm)
    core = strip_lot(core)
    core = re.sub(r"\s+"," ", (core or "").strip()).strip()
    usig = unit_signature(udes, uval)

    # UNIT-first
    if usig:
        for av, tag in addr_variants(core):
            keyu = f"{town_norm}|{av}|{usig}"
            if keyu in unit_index:
                if unit_index[keyu] == "__COLLISION__":
                    return ("UNKNOWN", None, "collision_unit", keyu)
                return ("ATTACHED_A", unit_index[keyu], f"unit|{tag}", keyu)

    # BASE fallback
    for av, tag in addr_variants(core):
        key = f"{town_norm}|{av}"
        if key in base_index:
            if base_index[key] == "__COLLISION__":
                return ("UNKNOWN", None, "collision_base", key)
            return ("ATTACHED_A", base_index[key], f"base|{tag}", key)

    # No match
    if usig:
        return ("UNKNOWN", None, "no_match_unit_then_base", f"{town_norm}|{core}|{usig}")
    return ("UNKNOWN", None, "no_match_base", f"{town_norm}|{core}")

# ------------------------------------------------------------
# Main
# ------------------------------------------------------------
def main():
    ap=argparse.ArgumentParser()
    ap.add_argument("--events", required=True)
    ap.add_argument("--spine", required=True)
    ap.add_argument("--out", required=True)
    ap.add_argument("--audit", required=True)
    ap.add_argument("--engine_id", default="events.registry_attach_to_spine_deterministic_v1_8")
    ap.add_argument("--county", default="")
    args=ap.parse_args()

    os.makedirs(os.path.dirname(args.out), exist_ok=True)
    os.makedirs(os.path.dirname(args.audit), exist_ok=True)

    towns=set()
    with open(args.events, "r", encoding="utf-8") as f:
        for line in f:
            line=line.strip()
            if not line:
                continue
            try:
                ev=json.loads(line)
            except Exception:
                continue
            pr = ev.get("property_ref") or {}
            t = town_canonical_from_event(pr) or norm_town(pr.get("town_norm") or pr.get("town_raw") or pr.get("town"))
            if t:
                towns.add(t)

    spine_ndjson = load_spine_pointer(args.spine)
    base_index, unit_index, spine_stats = build_spine_indices(spine_ndjson, towns)

    now_utc = datetime.now(timezone.utc)
    audit = {
        "run_id": f"{args.engine_id}|{args.county}|{sha256_text(args.events)[:12]}|{now_utc.strftime('%Y%m%dT%H%M%SZ')}",
        "created_at_utc": now_utc.isoformat().replace("+00:00","Z"),
        "engine_id": args.engine_id,
        "county": args.county,
        "events_in": args.events,
        "spine_pointer": args.spine,
        "spine_ndjson": spine_ndjson,
        "towns_used_count": len(towns),
        "spine_stats": spine_stats,
        "events_total": 0,
        "attach_status_counts": {},
        "method_counts": {},
    }

    def bump(d,k,n=1):
        d[k]=d.get(k,0)+n

    with open(args.events, "r", encoding="utf-8") as fin, open(args.out, "w", encoding="utf-8") as fout:
        for line in fin:
            line=line.strip()
            if not line:
                continue
            audit["events_total"] += 1
            ev=json.loads(line)

            pr = ev.get("property_ref") or {}
            town_norm = town_canonical_from_event(pr) or norm_town(pr.get("town_norm") or pr.get("town_raw") or pr.get("town"))
            addr_norm = norm_addr(pr.get("address_norm") or pr.get("address_raw") or pr.get("address"))

            ev.setdefault("attach", {})
            st,pid,meth,mkey = attach_one(town_norm, addr_norm, base_index, unit_index)

            ev["attach"]["attach_scope"]="SINGLE"
            ev["attach"]["attach_status"]=st
            ev["attach"]["property_id"]=pid
            ev["attach"]["match_method"]=meth
            ev["attach"]["match_key"]=mkey

            bump(audit["attach_status_counts"], st)
            bump(audit["method_counts"], meth or "none")

            fout.write(json.dumps(ev, ensure_ascii=False) + "\n")

    with open(args.audit, "w", encoding="utf-8") as f:
        json.dump(audit, f, indent=2)

    print(json.dumps(audit["attach_status_counts"], indent=2))
