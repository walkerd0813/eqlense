# =========================
# Equity Lens — Hampden ingestion scope
# =========================

# --- Never commit pipeline runtime/output ---
publicData/registry/hampden/_work/
publicData/registry/hampden/**/_work/
publicData/registry/hampden/incoming/
publicData/registry/hampden/**/incoming/

# --- Never commit big artifacts ---
**/*.pdf
**/*.zip

# --- Never commit secrets / env ---
.env
.env.*
**/.env
**/.env.*
mls/.env.mls

# --- Standard noise ---
node_modules/
__pycache__/
*.pyc
.vscode/
.idea/
_tmp/
**/_tmp/
logs/
**/logs/
cache/
**/cache/
Thumbs.db
.DS_Store

# --------------------
# Focus mode: ignore non-ingestion roots for now
# (keeps repo quiet while we work on Hampden ingestion)
# --------------------
publicData/
rawData/
uploads/
tools/
valuation/
zoning/
prisma/
schemas/
routes/
config/
analytics/
cache/
comps_geocoded/
mls/downloads/
mls/enriched/
mls/indexes/
mls/logs/
mls/manual_inbox/

# Ignore local backups + scratch
*.bak_*
*.BAK_*
*.bak
server.js.bak_*

# Ignore root-level phase4 configs during ingestion focus
phase4_*.json
testValuation.js
zoningDebugger.js
zoningTest.js