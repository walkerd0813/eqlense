# Ignore EVERYTHING by default
*

# Allow git to see these meta files
!.gitignore
!README.md
!LICENSE

# Allow top-level server/app code if you want to keep it
!server.js
!package.json
!package-lock.json

# Allow ingestion scripts (whitelist)
!scripts/
!scripts/**

# If you only want registry ingestion and not all scripts, use this instead:
# !scripts/_registry/
# !scripts/_registry/**
# !scripts/registry/
# !scripts/registry/**

# Allow minimal config you actually need (optional)
!ENGINE_REGISTRY.json
!services/
!services/**
!utils/
!utils/**