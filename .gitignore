# =========================
# Equity Lens — Hampden scope
# =========================

# Never commit work roots / outputs
publicData/registry/hampden/_work/
publicData/registry/hampden/incoming/
publicData/registry/hampden/**/_work/
publicData/registry/hampden/**/incoming/

# Never commit PDFs / big artifacts
**/*.pdf
**/*.zip

# Never commit env/secrets
.env
.env.*
**/.env
**/.env.*
mls/.env.mls

# Standard noise
node_modules/
__pycache__/
*.pyc
.vscode/
_tmp/
**/_tmp/
logs/
**/logs/