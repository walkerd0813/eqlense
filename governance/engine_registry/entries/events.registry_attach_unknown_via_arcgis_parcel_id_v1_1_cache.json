{
  "engine_id": "events.registry_attach_unknown_via_arcgis_parcel_id_v1_1_cache",
  "version": "v1_1_CACHE",
  "stage": "ATTACH",
  "family": "registry_events",
  "description": "Attach UNKNOWN registry events to property spine via ArcGIS MAP_PAR_ID lookup (cached), deterministic by parcel id.",
  "runner": {
    "cmd": "python",
    "args_template": ".\\scripts\\_registry\\attach\\events_attach_unknown_via_arcgis_parcel_id_v1_1_CACHE.py --events {events} --spine_index {spine_index} --town {town} --out {out} --audit {audit} --limit_unknown {limit_unknown} --sleep {sleep}",
    "script_relpath": "scripts\\_registry\\attach\\events_attach_unknown_via_arcgis_parcel_id_v1_1_CACHE.py",
    "script_relpath_aliases": [
      ".\\scripts\\_registry\\attach\\events_attach_unknown_via_arcgis_parcel_id_v1_1_CACHE.py"
    ],
    "promote_targets": [],
    "contract_status": "MISSING_RUNNER_CONTRACT",
    "notes": "Governance: deterministic attach via ArcGIS parcel id; wrapper can later supply {events}/{spine_index}/{out}/{audit} paths from CURRENT pointers."
  },
  "inputs": [
    { "key": "events", "required": true, "kind": "ndjson", "note": "Registry events NDJSON" },
    { "key": "spine_index", "required": true, "kind": "ndjson", "note": "spine_map_par_id__to_property_id index NDJSON" }
  ],
  "outputs": [
    { "key": "out", "kind": "ndjson", "note": "Events NDJSON with attach upgraded via parcel-id evidence" },
    { "key": "audit", "kind": "json", "note": "Counts + run metadata" }
  ],
  "params": {
    "town": { "type": "string", "required": true },
    "limit_unknown": { "type": "int", "default": 20000 },
    "sleep": { "type": "float", "default": 0.02 }
  },
  "journaling": {
    "emit_counts": [
      "unknown_seen_in_town",
      "cache_hit",
      "cache_miss",
      "arc_queries",
      "arc_hit",
      "arc_no_hit",
      "attached_via_arcgis",
      "arc_hit_no_spine_match",
      "no_num_or_core"
    ]
  },
  "gates": [
    { "gate_id": "SCOPE_ONLY_UNKNOWN", "rule": "Only mutate events where attach.status == UNKNOWN and town matches param.town" },
    { "gate_id": "ARC_HIT_NO_SPINE_MATCH_LOW", "rule": "If arc_hit_no_spine_match spikes, block promotion" },
    { "gate_id": "EVIDENCE_REQUIRED", "rule": "If attached_via_arcgis > 0 then evidence.arcgis.MAP_PAR_ID must exist" }
  ]
}
